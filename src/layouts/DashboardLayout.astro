---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import MobileNav from "../components/MobileNav.astro";
import { withBase } from "../lib/base";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
		<link rel="icon" href={withBase("/favicon.ico")} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			const stored = localStorage.getItem("theme");
			const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
			const theme = stored || (systemDark ? "dark" : "light");
			document.documentElement.setAttribute("data-theme", theme);

			// Sidebar collapsed/expanded — set pre-paint to avoid a width flash.
			const sidebar = localStorage.getItem("sidebar") === "collapsed" ? "collapsed" : "expanded";
			document.documentElement.setAttribute("data-sidebar", sidebar);
		</script>
	</head>
	<body>
		<Sidebar />
		<MobileNav />
		<main>
			<div class="page">
				<slot />
			</div>
		</main>
	</body>
</html>

<style is:global>
	body {
		display: block;
		height: auto;
		/* overflow: visible (not auto/hidden) so the html/viewport handles
		   scrolling. Required for descendant position: sticky to work —
		   overflow: auto would create a separate scroll context that breaks it,
		   and global.css sets body { overflow: hidden } which we must override. */
		overflow: visible;
	}

	/* Sidebar footprint drives the main offset. --sidebar-w flips between
	   280px (expanded) and 84px (collapsed); +32px = 16 left inset + 16 gap. */
	:root {
		--sidebar-w: 280px;
	}

	:root[data-sidebar="collapsed"] {
		--sidebar-w: 84px;
	}

	main {
		margin-left: calc(var(--sidebar-w) + 32px);
		min-height: 100vh;
		/* Override global.css main { overflow: hidden } — that rule was for
		   the old slideshow app and breaks descendant position: sticky. */
		overflow: visible;
		transition: margin-left 320ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.page {
		max-width: 1080px;
		margin: 0 auto;
		padding: 80px 48px 48px;
	}

	.page-header {
		margin-bottom: 56px;
	}

	.page-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: clamp(40px, 5vw, 64px);
		font-weight: 600;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--text-primary);
		margin: 0 0 16px;
	}

	.page-subtitle {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-lg);
		line-height: 1.5;
		color: var(--text-secondary);
		max-width: 560px;
		margin: 0;
	}

	.page-actions {
		display: flex;
		gap: 12px;
		margin-top: 28px;
		flex-wrap: wrap;
	}

	.page-button {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 18px;
		border-radius: 12px;
		border: 1px solid var(--border);
		background-color: var(--bg-primary);
		color: var(--text-primary);
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 600;
		text-decoration: none;
		cursor: pointer;
		transition: background-color var(--transition-fast),
			border-color var(--transition-fast);
	}

	.page-button:hover {
		background-color: var(--bg-secondary);
	}

	.page-button-icon {
		width: 16px;
		height: 16px;
	}

	@media (max-width: 768px) {
		main {
			margin-left: 0;
			padding-top: 80px;
		}

		.page {
			padding: 24px 20px 40px;
		}

		.page-header {
			margin-bottom: 32px;
		}
	}
</style>
