---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const recentProjects = [
	{
		name: "Milkyway Glass",
		category: "E-commerce UX",
		year: "2024",
		thumbnail: "/images/Laptop Mockup.png",
		thumbnailAlt: "Milkyway Glass on a laptop",
		videoSrc: "/videos/Portfolio-MK-Desktop.mp4",
		mockupAspect: "3750 / 4906",
		mockupMax: "120%",
		mockupOffsetY: "50px",
		screenTop: "1.5%",
		screenLeft: "7%",
		screenWidth: "86%",
		screenHeight: "43.5%",
		href: "/projects/milkyway-glass",
	},
	{
		name: "O3 Drinkware",
		category: "Responsive web",
		year: "2024",
		thumbnail: "/images/RS-Mockup.png",
		thumbnailAlt: "O3 Drinkware on a desktop monitor",
		videoSrc: "/videos/O3-Portfolio-Front_A.mp4",
		mockupAspect: "3463 / 3083",
		screenTop: "3%",
		screenLeft: "3%",
		screenWidth: "94%",
		screenHeight: "65%",
		href: "/projects/o3-drinkware",
	},
];

// Brand logos fetched from the simple-icons CDN, mirroring the Stack page.
const si = (slug: string) => `https://cdn.jsdelivr.net/npm/simple-icons/icons/${slug}.svg`;

// Low-luminance brand marks are lightened in dark mode so they stay legible.
const isDarkBrand = (hex: string) => {
	const c = hex.replace("#", "");
	const r = parseInt(c.slice(0, 2), 16);
	const g = parseInt(c.slice(2, 4), 16);
	const b = parseInt(c.slice(4, 6), 16);
	return (0.299 * r + 0.587 * g + 0.114 * b) / 255 < 0.22;
};

const stackPreview = [
	{ name: "Figma", sublabel: "Design tool", icon: si("figma"), letter: "F", color: "#F24E1E" },
	{ name: "Claude", sublabel: "Reasoning & code", icon: si("claude"), letter: "C", color: "#D97757" },
	{ name: "Cursor", sublabel: "AI-first editor", icon: si("cursor"), letter: "C", color: "#1A1A1A" },
	{ name: "Webflow", sublabel: "Visual web builder", icon: si("webflow"), letter: "W", color: "#146EF5" },
];
---

<DashboardLayout title="Andrew Baek — Product Designer">
	<header class="page-header">
		<h1 class="page-title">Designing products people actually use.</h1>
		<p class="page-subtitle">
			Product designer in Toronto with an industrial design background.
			Currently shipping at MedMe Health and building toward product with
			AI in the loop.
		</p>
		<div class="page-actions">
			<a href="/about" class="page-button">About</a>
			<a href="/contact" class="page-button">
				<svg class="page-button-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
					<polyline points="22,6 12,13 2,6"/>
				</svg>
				Email
			</a>
			<a href="https://www.linkedin.com/in/andrew-baek-a29388202/" class="page-button" target="_blank" rel="noopener noreferrer">
				<svg class="page-button-icon" viewBox="0 0 24 24" fill="currentColor" stroke="none">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
				LinkedIn
			</a>
			<a href="https://www.instagram.com/andrew__baek/" class="page-button" target="_blank" rel="noopener noreferrer">
				<svg class="page-button-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
					<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
					<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
				</svg>
				Instagram
			</a>
		</div>
	</header>

	<!-- Recent Work -->
	<section class="home-section">
		<div class="home-section-head">
			<h2 class="home-section-title">Recent Work</h2>
			<a href="/projects" class="home-section-link">
				All projects
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"/>
					<polyline points="12 5 19 12 12 19"/>
				</svg>
			</a>
		</div>
		<div class="home-grid-projects">
			{recentProjects.map((project) => <ProjectCard {...project} />)}
		</div>
	</section>

	<!-- Stack preview -->
	<section class="home-section">
		<div class="home-section-card">
			<div class="home-section-head">
				<div>
					<h2 class="home-section-title">Stack</h2>
					<p class="home-section-sub">Tools I reach for daily.</p>
				</div>
				<a href="/stack" class="home-section-link">
					View all
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="5" y1="12" x2="19" y2="12"/>
						<polyline points="12 5 19 12 12 19"/>
					</svg>
				</a>
			</div>
			<div class="home-stack-grid">
				{stackPreview.map((item) => (
					<div class="home-stack-item">
						<span
							class="home-stack-icon"
							style={`--brand: ${item.color}; --logo-url: url('${item.icon}')`}
						>
							<span
								class:list={["home-stack-logo", { "is-dark-brand": isDarkBrand(item.color) }]}
								role="img"
								aria-label={`${item.name} logo`}
							></span>
						</span>
						<div class="home-stack-text">
							<p class="home-stack-name">{item.name}</p>
							<p class="home-stack-sub">{item.sublabel}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- About + Contact previews -->
	<section class="home-section">
		<div class="home-pair">
			<a href="/about" class="home-card">
				<div class="home-card-head">
					<span class="home-card-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
							<circle cx="12" cy="7" r="4"/>
						</svg>
					</span>
					<svg class="home-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="7" y1="17" x2="17" y2="7"/>
						<polyline points="7 7 17 7 17 17"/>
					</svg>
				</div>
				<h3 class="home-card-title">A product designer with an industrial design brain.</h3>
				<p class="home-card-text">
					Trained on objects, fluent in pixels. Tight feedback loops,
					deliberate decisions, and craft over tooling.
				</p>
			</a>
			<a href="/contact" class="home-card">
				<div class="home-card-head">
					<span class="home-card-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
					</svg>
					</span>
					<svg class="home-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="7" y1="17" x2="17" y2="7"/>
						<polyline points="7 7 17 7 17 17"/>
					</svg>
				</div>
				<h3 class="home-card-title">Let's make something together.</h3>
				<p class="home-card-text">
					Working on something that needs a designer with strategy and
					craft? Say hello — I'd love to chat.
				</p>
			</a>
		</div>
	</section>
</DashboardLayout>

<style>
	/* Home hero actions render as pills to match the updated site theme */
	.page-actions :global(.page-button) {
		border-radius: 9999px;
	}

	.home-section {
		margin-bottom: 32px;
	}

	.home-section-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 20px;
	}

	.home-section-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-sm);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0;
		letter-spacing: -0.02em;
	}

	.home-section-sub {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		margin: 4px 0 0;
	}

	.home-section-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
		flex-shrink: 0;
	}

	.home-section-link:hover {
		color: var(--text-primary);
	}

	.home-section-link svg {
		width: 14px;
		height: 14px;
	}

	/* Recent Work grid (projects) — auto-fit so columns drop to 1 when there's no room */
	.home-grid-projects {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 20px;
	}

	/* Section card — wraps Stack preview etc. */
	.home-section-card {
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 24px 24px 28px;
		background-color: var(--bg-primary);
	}

	.home-section-card .home-section-head {
		margin-bottom: 24px;
	}

	/* Stack preview grid */
	.home-stack-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 16px 24px;
	}

	.home-stack-item {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.home-stack-icon {
		position: relative;
		width: 40px;
		height: 40px;
		border-radius: 11px;
		border: 1px solid color-mix(in srgb, var(--brand) 26%, transparent);
		background-color: color-mix(in srgb, var(--brand) 14%, transparent);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.home-stack-logo {
		width: 22px;
		height: 22px;
		background-color: var(--brand, var(--text-primary));
		-webkit-mask: var(--logo-url) center / contain no-repeat;
		mask: var(--logo-url) center / contain no-repeat;
	}

	/* Near-black brand marks would disappear on a dark tile — lighten them */
	:global([data-theme="dark"]) .home-stack-logo.is-dark-brand {
		background-color: #f0f0f0;
	}

	.home-stack-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.home-stack-name {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.2;
	}

	.home-stack-sub {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.3;
	}

	/* About + Contact pair */
	.home-pair {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 20px;
	}

	.home-card {
		display: flex;
		flex-direction: column;
		gap: 14px;
		padding: 24px;
		border: 1px solid var(--border);
		border-radius: 20px;
		/* --bg-secondary is the lightest grey token; default so it reads clickable */
		background-color: var(--bg-secondary);
		text-decoration: none;
		cursor: pointer;
		transition: border-color var(--transition-fast),
			transform var(--transition-fast),
			background-color var(--transition-fast);
	}

	.home-card:hover {
		border-color: var(--text-muted);
		transform: translateY(-2px);
	}

	.home-card-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.home-card-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--text-primary);
	}

	.home-card-icon svg {
		width: 26px;
		height: 26px;
	}

	.home-card-arrow {
		width: 16px;
		height: 16px;
		color: var(--text-muted);
		transition: color var(--transition-fast);
	}

	.home-card:hover .home-card-arrow {
		color: var(--text-primary);
	}

	.home-card-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-lg);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.3;
		letter-spacing: -0.01em;
	}

	.home-card-text {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.5;
	}

	@media (max-width: 768px) {
		.home-grid-projects,
		.home-stack-grid,
		.home-pair {
			grid-template-columns: 1fr;
		}
	}
</style>
