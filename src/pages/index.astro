---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const recentProjects = [
	{
		name: "Milkyway Glass",
		category: "E-commerce UX",
		year: "2024",
		thumbnail: "/images/Laptop Mockup.png",
		thumbnailAlt: "Milkyway Glass on a laptop",
		videoSrc: "/videos/Portfolio-MK-Desktop.mp4",
		mockupAspect: "3750 / 4906",
		mockupMax: "120%",
		mockupOffsetY: "50px",
		screenTop: "1.5%",
		screenLeft: "7%",
		screenWidth: "86%",
		screenHeight: "43.5%",
		href: "/projects",
	},
	{
		name: "O3 Drinkware",
		category: "Responsive web",
		year: "2024",
		thumbnail: "/images/RS-Mockup.png",
		thumbnailAlt: "O3 Drinkware on a desktop monitor",
		videoSrc: "/videos/O3-Portfolio-Front_A.mp4",
		mockupAspect: "3463 / 3083",
		screenTop: "3%",
		screenLeft: "3%",
		screenWidth: "94%",
		screenHeight: "65%",
		href: "/projects",
	},
];
---

<DashboardLayout title="Andrew Baek — Product Designer">
	<header class="page-header">
		<h1 class="page-title">Designing products people actually use.</h1>
		<p class="page-subtitle">
			Product designer in Toronto with an industrial design background.
			Currently shipping at MedMe Health and building toward product with
			AI in the loop.
		</p>
		<div class="page-actions">
			<a href="/about" class="page-button">About</a>
			<a href="/contact" class="page-button">
				<svg class="page-button-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
					<polyline points="22,6 12,13 2,6"/>
				</svg>
				Email
			</a>
		</div>
	</header>

	<section class="home-section">
		<div class="home-section-head">
			<h2 class="home-section-title">Recent Work</h2>
			<a href="/projects" class="home-section-link">
				All projects
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"/>
					<polyline points="12 5 19 12 12 19"/>
				</svg>
			</a>
		</div>
		<div class="home-grid">
			{recentProjects.map((project) => <ProjectCard {...project} />)}
		</div>
	</section>
</DashboardLayout>

<style>
	.home-section {
		margin-bottom: 56px;
	}

	.home-section-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 20px;
	}

	.home-section-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-sm);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0;
		letter-spacing: -0.02em;
	}

	.home-section-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.home-section-link:hover {
		color: var(--text-primary);
	}

	.home-section-link svg {
		width: 14px;
		height: 14px;
	}

	.home-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
	}

	@media (max-width: 768px) {
		.home-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
