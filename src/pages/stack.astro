---
import DashboardLayout from "../layouts/DashboardLayout.astro";

interface StackItem {
	name: string;
	sublabel: string;
	/** Remote brand-logo SVG URL (null = no reliable CDN source, use fallback). */
	icon: string | null;
	/** Fallback monogram shown if the remote logo fails to load. */
	letter: string;
	color: string;
}

interface StackCategory {
	title: string;
	items: StackItem[];
}

// Official brand logos are fetched at runtime from the simple-icons CDN
// (jsdelivr). A handful of brands were removed from the latest simple-icons
// for trademark reasons, so those are pinned to simple-icons@11 which still
// ships them. SVGs are monochrome (black) and inverted to white in dark mode.
const si = (slug: string) => `https://cdn.jsdelivr.net/npm/simple-icons/icons/${slug}.svg`;
const si11 = (slug: string) => `https://cdn.jsdelivr.net/npm/simple-icons@11/icons/${slug}.svg`;

// A brand mark counts as "dark" when its colour is low-luminance. Those are
// lightened in dark mode so they stay legible on the dark tile — this is what
// rescues the Slack logo (#4A154B), which is otherwise illegible in dark mode.
const isDarkBrand = (hex: string) => {
	const c = hex.replace("#", "");
	const r = parseInt(c.slice(0, 2), 16);
	const g = parseInt(c.slice(2, 4), 16);
	const b = parseInt(c.slice(4, 6), 16);
	return (0.299 * r + 0.587 * g + 0.114 * b) / 255 < 0.22;
};

const stack: StackCategory[] = [
	{
		title: "Design",
		items: [
			{ name: "Figma", sublabel: "Design tool", icon: si("figma"), letter: "F", color: "#F24E1E" },
			{ name: "Adobe Photoshop", sublabel: "Raster editing", icon: si11("adobephotoshop"), letter: "Ps", color: "#31A8FF" },
			{ name: "Adobe Illustrator", sublabel: "Vector design", icon: si11("adobeillustrator"), letter: "Ai", color: "#FF9A00" },
			{ name: "Adobe InDesign", sublabel: "Layout & print", icon: si11("adobeindesign"), letter: "Id", color: "#FF3366" },
			{ name: "Adobe Creative Suite", sublabel: "Creative tools", icon: si11("adobecreativecloud"), letter: "Cc", color: "#DA1F26" },
		],
	},
	{
		title: "Artificial Intelligence",
		items: [
			{ name: "Claude", sublabel: "Reasoning & code", icon: si("claude"), letter: "C", color: "#D97757" },
			{ name: "ChatGPT", sublabel: "General assistant", icon: si11("openai"), letter: "G", color: "#10A37F" },
			{ name: "Codex", sublabel: "AI coding agent", icon: si11("openai"), letter: "C", color: "#10A37F" },
			{ name: "Cursor", sublabel: "AI-first editor", icon: si("cursor"), letter: "C", color: "#1A1A1A" },
			{ name: "Gemini", sublabel: "Multimodal AI", icon: si("googlegemini"), letter: "G", color: "#8E75F8" },
		],
	},
	{
		title: "Build & CMS",
		items: [
			{ name: "Webflow", sublabel: "Visual web builder", icon: si("webflow"), letter: "W", color: "#146EF5" },
			{ name: "WordPress", sublabel: "Content management", icon: si("wordpress"), letter: "W", color: "#21759B" },
			{ name: "Shopify", sublabel: "E-commerce platform", icon: si("shopify"), letter: "S", color: "#7AB55C" },
			{ name: "Wix", sublabel: "Website builder", icon: si("wix"), letter: "W", color: "#0C6EFC" },
			{ name: "Squarespace", sublabel: "Website builder", icon: si("squarespace"), letter: "S", color: "#1A1A1A" },
		],
	},
	{
		title: "Development",
		items: [
			{ name: "VS Code", sublabel: "Code editor", icon: si11("visualstudiocode"), letter: "V", color: "#007ACC" },
			{ name: "GitHub", sublabel: "Source control", icon: si("github"), letter: "G", color: "#1A1A1A" },
			{ name: "Vercel", sublabel: "Hosting", icon: si("vercel"), letter: "V", color: "#1A1A1A" },
			{ name: "Astro", sublabel: "Web framework", icon: si("astro"), letter: "A", color: "#FF5D01" },
		],
	},
	{
		title: "Productivity",
		items: [
			{ name: "Notion", sublabel: "Docs & wiki", icon: si("notion"), letter: "N", color: "#1A1A1A" },
			{ name: "Slack", sublabel: "Team collaboration", icon: si11("slack"), letter: "S", color: "#4A154B" },
			{ name: "Asana", sublabel: "Work management", icon: si("asana"), letter: "A", color: "#F06A6A" },
			{ name: "Jira", sublabel: "Issue tracking", icon: si("jira"), letter: "J", color: "#0052CC" },
			{ name: "ClickUp", sublabel: "Project management", icon: si("clickup"), letter: "C", color: "#7B68EE" },
		],
	},
	{
		title: "Marketing",
		items: [
			{ name: "HubSpot", sublabel: "CRM platform", icon: si("hubspot"), letter: "H", color: "#FF7A59" },
			{ name: "Mailchimp", sublabel: "Email marketing", icon: si("mailchimp"), letter: "M", color: "#FFE01B" },
			{ name: "Klaviyo", sublabel: "Marketing automation", icon: "/images/klaviyo.svg", letter: "K", color: "#1A1A1A" },
		],
	},
];
---

<DashboardLayout title="Stack — Andrew Baek">
	<header class="page-header">
		<h1 class="page-title">Stack</h1>
		<p class="page-subtitle">
			Tools and resources I use daily.
		</p>
	</header>

	<div class="stack-list">
		{stack.map((section) => (
			<section class="stack-section">
				<h2 class="stack-section-title">{section.title}</h2>
				<div class="stack-grid">
					{section.items.map((item) => (
						<div class="stack-item">
							<span
								class="stack-item-icon"
								style={`--brand: ${item.color}; --logo-url: url('${item.icon}')`}
							>
								<span
									class:list={["stack-logo", { "is-dark-brand": isDarkBrand(item.color) }]}
									role="img"
									aria-label={`${item.name} logo`}
								></span>
							</span>
							<div class="stack-item-text">
								<p class="stack-item-name">{item.name}</p>
								<p class="stack-item-sub">{item.sublabel}</p>
							</div>
						</div>
					))}
				</div>
			</section>
		))}
	</div>
</DashboardLayout>

<style>
	.stack-list {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.stack-section {
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 24px 24px 28px;
		background-color: var(--bg-primary);
	}

	.stack-section-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-lg);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0 0 20px;
	}

	.stack-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 16px 24px;
	}

	.stack-item {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	/* Logo tile — softly tinted with the brand colour */
	.stack-item-icon {
		position: relative;
		width: 44px;
		height: 44px;
		border-radius: 12px;
		border: 1px solid color-mix(in srgb, var(--brand) 26%, transparent);
		background-color: color-mix(in srgb, var(--brand) 14%, transparent);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	/* Logo drawn as a mask filled with the brand colour */
	.stack-logo {
		width: 24px;
		height: 24px;
		background-color: var(--brand, var(--text-primary));
		-webkit-mask: var(--logo-url) center / contain no-repeat;
		mask: var(--logo-url) center / contain no-repeat;
	}

	/* Near-black brand marks would disappear on a dark tile — lighten them */
	:global([data-theme="dark"]) .stack-logo.is-dark-brand {
		background-color: #f0f0f0;
	}

	.stack-item-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.stack-item-name {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.2;
	}

	.stack-item-sub {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.3;
	}

	@media (max-width: 768px) {
		.stack-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
