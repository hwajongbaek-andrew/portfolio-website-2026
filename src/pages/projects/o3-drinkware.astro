---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const facts = [
	{ label: "Year", value: "2024–25" },
	{ label: "Type", value: "Responsive website redesign" },
	{ label: "Role", value: "Web & UX/UI designer" },
	{ label: "Tools", value: "Figma, Shopify, Adobe CC" },
];

const metrics = [
	{ value: "4D", label: "Discover → Define → Develop → Deliver" },
	{ value: "2", label: "User personas guiding decisions" },
	{ value: "6", label: "Core design features shipped" },
	{ value: "2 mo", label: "Concept to delivery (Nov '24 – Jan '25)" },
];

const directions = [
	{ value: "01", label: "Modern aesthetics" },
	{ value: "02", label: "Brand storytelling" },
	{ value: "03", label: "Intuitive navigation" },
];

const solutionFeatures = [
	{
		title: "A modern reflection of O3",
		text: "A clean, contemporary design that embodies O3's sleek, modern brand identity from the first scroll.",
	},
	{
		title: "Bringing O3's values to life",
		text: "Thoughtful design and content surface O3's values of innovation and artistry to connect with users.",
	},
	{
		title: "With and without liquid",
		text: "Product photography shows each tumbler both filled and empty — communicating versatility at a glance.",
	},
	{
		title: "Aqueduct (water-way) technology",
		text: "A dedicated section spotlights O3's proprietary water-management system as a hero differentiator.",
	},
	{
		title: "Navigation that flows",
		text: "Intuitive navigation lets users explore and reach the right product in just a few clicks.",
	},
	{
		title: "Simplified for every click",
		text: "Streamlined, mobile-friendly product pages strip out friction on the path to checkout.",
	},
];

const takeaways = [
	{
		title: "User-centered approach",
		text: "Prioritizing the user experience kept navigation seamless and product discovery effortless.",
	},
	{
		title: "Brand alignment",
		text: "Aligning the design with O3's identity let the site reflect the company's values and aesthetics.",
	},
	{
		title: "Mobile-first design",
		text: "Optimizing for mobile was essential to keep the experience performant on every device.",
	},
	{
		title: "Effective storytelling",
		text: "Design and content working together built a stronger emotional connection beyond the products.",
	},
];

const related = [
	{
		name: "Milkyway Glass",
		category: "E-commerce UX & retention",
		year: "2024",
		thumbnail: "/images/Laptop Mockup.png",
		thumbnailAlt: "Milkyway Glass on a laptop",
		videoSrc: "/videos/Portfolio-MK-Desktop.mp4",
		mockupAspect: "3750 / 4906",
		mockupMax: "120%",
		mockupOffsetY: "50px",
		screenTop: "1.5%",
		screenLeft: "7%",
		screenWidth: "86%",
		screenHeight: "43.5%",
		href: "/projects/milkyway-glass",
	},
	{
		name: "Seeders",
		category: "Multi-sided platform UX",
		year: "2021",
		thumbnail: "/images/Seeders_Mockup_E04.jpg",
		thumbnailAlt: "Seeders mobile app screens",
		href: "/projects/seeders",
	},
];
---

<DashboardLayout title="O3 Drinkware — Andrew Baek">
	<a href="/projects" class="project-breadcrumb">
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="19" y1="12" x2="5" y2="12"/>
			<polyline points="12 19 5 12 12 5"/>
		</svg>
		All projects
	</a>

	<!-- Header: eyebrow, title, summary, inline facts -->
	<header class="project-header">
		<p class="project-eyebrow">Responsive Website Redesign</p>
		<h1 class="project-title">O3 Drinkware</h1>
		<p class="project-summary">
			A sleek, user-focused e-commerce platform for a premium glass
			drinkware brand — pairing innovative product technology with artistic
			design and a frictionless shopping flow.
		</p>

		<ul class="project-facts">
			{facts.map((f) => (
				<li class="project-fact">
					<span class="project-fact-label">{f.label}</span>
					<span class="project-fact-value">{f.value}</span>
				</li>
			))}
		</ul>
	</header>

	<!-- Hero visual -->
	<div class="project-hero">
		<div class="project-hero-mockup">
			<img
				src="/images/RS-Mockup.png"
				alt="O3 Drinkware website preview on a desktop monitor"
				class="project-hero-mockup-frame"
			/>
			<video
				class="project-hero-mockup-video"
				autoplay
				loop
				muted
				playsinline
				preload="metadata"
			>
				<source src="/videos/O3-Portfolio-Front_A.mp4" type="video/mp4" />
			</video>
		</div>
	</div>

	<!-- Impact / project at a glance -->
	<section class="project-impact">
		<h2 class="project-impact-title">At a glance</h2>
		<div class="project-impact-grid">
			{metrics.map((m) => (
				<div class="project-impact-card">
					<p class="project-impact-value">{m.value}</p>
					<p class="project-impact-label">{m.label}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Two-column body: editorial prose + sticky TOC -->
	<div class="project-layout">
		<article class="project-body">
			<h2 class="project-h2" id="overview">Overview</h2>
			<p class="project-prose">
				The O3 Drinkware website is a sleek, user-focused e-commerce
				platform that showcases premium glass drinkware combining
				innovative technology with artistic design. I focused on clean,
				modern layouts that highlight the brand identity while keeping
				navigation easy — pairing high-quality imagery and detailed
				product descriptions with a responsive design that holds up across
				every device.
			</p>

			<h2 class="project-h2" id="challenge">The challenge</h2>
			<p class="project-prose">
				O3 Drinkware needed a visually compelling, user-friendly platform
				that reflects its innovative design values while keeping shopping
				effortless. The guiding design question:
				<strong>How might we create an intuitive and engaging website that
				showcases O3's artistry and enhances the user experience?</strong>
			</p>
			<p class="project-prose">
				Research into the target audience surfaced recurring friction:
			</p>
			<ul class="project-list">
				<li><strong>Hard to find unique, high-quality drinkware</strong> worth the premium.</li>
				<li><strong>Cluttered layouts</strong> that buried the product instead of celebrating it.</li>
				<li><strong>Poor mobile experience</strong> on sites built desktop-first.</li>
				<li><strong>Limited browsing time</strong> — shoppers need to find the right gift fast.</li>
				<li><strong>Missing product details</strong> that left buyers unsure before purchase.</li>
			</ul>

			<h2 class="project-h2" id="process">Process</h2>
			<p class="project-prose">
				I structured the work around the <strong>4D method</strong> —
				Discover, Define, Develop, and Deliver — to move from brand
				understanding to a shippable design without skipping the thinking
				in between.
			</p>
			<ul class="project-list">
				<li><strong>Discover</strong> — learned O3's brand goals: a strong online presence reflecting innovation and artistry for its unique glass tumblers.</li>
				<li><strong>Define</strong> — built two personas (Emily, a graphic designer who wants visually stunning products with easy navigation; Sophia, an interior designer who needs to quickly browse and find the perfect gift) and mapped the user journey from discovery to purchase.</li>
				<li><strong>Develop</strong> — produced a site map and wireframes to lock in a logical flow and clear product presentation.</li>
				<li><strong>Deliver</strong> — translated it into a responsive, on-brand final design.</li>
			</ul>
			<p class="project-prose">
				Defining the work this way pointed to four clear directions:
			</p>
			<ul class="project-metrics project-metrics-baseline">
				{directions.map((d) => (
					<li class="project-metric project-metric-baseline">
						<span class="project-metric-value">{d.value}</span>
						<span class="project-metric-label">{d.label}</span>
					</li>
				))}
			</ul>

			<figure class="project-figure project-figure--research">
				<div class="project-figure-frame" aria-hidden="true">
					<div class="project-figure-grid">
						<div class="project-figure-hot project-figure-hot-1"></div>
						<div class="project-figure-hot project-figure-hot-2"></div>
						<div class="project-figure-hot project-figure-hot-3"></div>
					</div>
					<span class="project-figure-tag">Personas · journey map · directions</span>
				</div>
				<figcaption class="project-figure-caption">
					Define-phase artifacts — personas and a user journey map that
					grounded the design in real shopper goals.
				</figcaption>
			</figure>

			<h2 class="project-h2" id="hmw">How might we</h2>
			<p class="project-prose">
				One question framed every decision:
			</p>
			<ul class="project-list">
				<li>How might we <strong>showcase O3's artistry</strong> while keeping the experience intuitive?</li>
				<li>How might we <strong>tell the brand story</strong> so the values land as clearly as the products?</li>
				<li>How might we <strong>streamline shopping</strong> for mobile, where most browsing happens?</li>
			</ul>

			<h2 class="project-h2" id="approach">The approach</h2>
			<p class="project-prose">
				The Deliver phase turned those directions into six concrete design
				moves:
			</p>

			<figure class="project-figure project-figure--solution">
				<div class="project-figure-frame" aria-hidden="true">
					<div class="project-figure-screens">
						<div class="project-figure-screen project-figure-screen-1">
							<div class="project-figure-bar"></div>
							<div class="project-figure-block"></div>
							<div class="project-figure-block project-figure-block--sm"></div>
						</div>
						<div class="project-figure-screen project-figure-screen-2">
							<div class="project-figure-bar"></div>
							<div class="project-figure-cards">
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
							</div>
						</div>
						<div class="project-figure-screen project-figure-screen-3">
							<div class="project-figure-bar"></div>
							<div class="project-figure-cards">
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
							</div>
							<div class="project-figure-block project-figure-block--sm"></div>
						</div>
					</div>
					<span class="project-figure-tag">Homepage · product page · Aqueduct tech</span>
				</div>
				<figcaption class="project-figure-caption">
					Key screens from the build — a brand-led homepage, versatile
					product photography, and a dedicated Aqueduct technology story.
				</figcaption>
			</figure>
			<div class="project-feature-grid">
				{solutionFeatures.map((f, i) => (
					<div class="project-feature">
						<span class="project-feature-index">{String(i + 1).padStart(2, "0")}</span>
						<div class="project-feature-text">
							<h3 class="project-feature-title">{f.title}</h3>
							<p class="project-feature-sub">{f.text}</p>
						</div>
					</div>
				))}
			</div>

			<h2 class="project-h2" id="outcomes">Outcomes</h2>
			<p class="project-prose">
				The result is a responsive storefront that feels as considered as
				the product itself — and the takeaways carried beyond this one
				project:
			</p>

			<figure class="project-figure project-figure--results">
				<div class="project-figure-frame" aria-hidden="true">
					<svg class="project-figure-chart" viewBox="0 0 320 140" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
						<defs>
							<linearGradient id="o3-line-fill" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="currentColor" stop-opacity="0.28"/>
								<stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
							</linearGradient>
						</defs>
						<path d="M 0 100 L 320 96" stroke="currentColor" stroke-opacity="0.3" stroke-width="2" stroke-dasharray="4 4" fill="none"/>
						<path d="M 0 105 C 60 100, 120 80, 180 55 S 280 25, 320 18 L 320 140 L 0 140 Z" fill="url(#o3-line-fill)"/>
						<path d="M 0 105 C 60 100, 120 80, 180 55 S 280 25, 320 18" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"/>
					</svg>
					<span class="project-figure-tag">Brand clarity · usability · mobile</span>
				</div>
				<figcaption class="project-figure-caption">
					A modern, responsive storefront that strengthens brand
					perception and smooths the path to purchase.
				</figcaption>
			</figure>
			<div class="project-feature-grid">
				{takeaways.map((t) => (
					<div class="project-feature">
						<div class="project-feature-text">
							<h3 class="project-feature-title">{t.title}</h3>
							<p class="project-feature-sub">{t.text}</p>
						</div>
					</div>
				))}
			</div>
		</article>

		<!-- Sticky table of contents -->
		<div class="project-toc-cell">
			<aside class="project-toc" aria-label="On this page">
				<p class="project-toc-label">On this page</p>
				<ul class="project-toc-list">
					<li><a href="#overview" class="project-toc-link" data-toc-link>Overview</a></li>
					<li><a href="#challenge" class="project-toc-link" data-toc-link>The challenge</a></li>
					<li><a href="#process" class="project-toc-link" data-toc-link>Process</a></li>
					<li><a href="#hmw" class="project-toc-link" data-toc-link>How might we</a></li>
					<li><a href="#approach" class="project-toc-link" data-toc-link>The approach</a></li>
					<li><a href="#outcomes" class="project-toc-link" data-toc-link>Outcomes</a></li>
				</ul>
			</aside>
		</div>
	</div>

	<!-- Related projects -->
	<section class="project-related">
		<div class="project-related-head">
			<h2 class="project-h2">More work</h2>
			<a href="/projects" class="project-related-link">
				All projects
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"/>
					<polyline points="12 5 19 12 12 19"/>
				</svg>
			</a>
		</div>
		<div class="project-related-grid">
			{related.map((project) => <ProjectCard {...project} />)}
		</div>
	</section>
</DashboardLayout>

<style>
	/* Breadcrumb */
	.project-breadcrumb {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		margin-bottom: 32px;
		transition: color var(--transition-fast);
	}

	.project-breadcrumb:hover {
		color: var(--text-primary);
	}

	.project-breadcrumb svg {
		width: 14px;
		height: 14px;
	}

	/* Header */
	.project-header {
		margin-bottom: 56px;
	}

	.project-eyebrow {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-accent);
		margin: 0 0 12px;
	}

	.project-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: clamp(40px, 5vw, 64px);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--text-primary);
		margin: 0 0 20px;
	}

	.project-summary {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-lg);
		line-height: 1.5;
		color: var(--text-secondary);
		max-width: 640px;
		margin: 0 0 28px;
	}

	/* Facts as inline pills */
	.project-facts {
		list-style: none;
		padding: 0;
		margin: 0 0 12px;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.project-fact {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 6px 12px;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
	}

	.project-fact-label {
		color: var(--text-muted);
		font-weight: 500;
	}

	.project-fact-value {
		color: var(--text-primary);
		font-weight: 600;
	}

	/* Metric pills */
	.project-metrics {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.project-metric {
		display: inline-flex;
		align-items: baseline;
		gap: 8px;
		padding: 6px 14px;
		border: 1px solid var(--text-accent);
		border-radius: 999px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
	}

	.project-metric-value {
		color: var(--text-accent);
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}

	.project-metric-label {
		color: var(--text-secondary);
	}

	.project-metrics-baseline {
		margin: 16px 0 24px;
	}

	.project-metric-baseline {
		border-color: var(--border);
	}

	.project-metric-baseline .project-metric-value {
		color: var(--text-secondary);
	}

	/* Hero visual */
	.project-hero {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 10;
		border-radius: 24px;
		overflow: hidden;
		background: var(--accent-gradient, linear-gradient(to bottom, #F99E67, #FAB771));
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 64px;
	}

	/* O3 uses a desktop-monitor mockup (wider than Milkyway's laptop) */
	.project-hero-mockup {
		position: relative;
		aspect-ratio: 3463 / 3083;
		max-width: 82%;
		max-height: 94%;
		transform: translateY(6px);
	}

	.project-hero-mockup-frame {
		position: relative;
		z-index: 1;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		pointer-events: none;
	}

	.project-hero-mockup-video {
		position: absolute;
		z-index: 2;
		top: 3%;
		left: 3%;
		width: 94%;
		height: 65%;
		object-fit: cover;
		display: block;
		border-radius: 4px;
	}

	/* Impact card section */
	.project-impact {
		margin-bottom: 64px;
	}

	.project-impact-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-muted);
		margin: 0 0 16px;
	}

	.project-impact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 16px;
	}

	.project-impact-card {
		padding: 24px 24px 22px;
		border: 1px solid var(--border);
		border-radius: 18px;
	}

	.project-impact-value {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-md);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--text-accent);
		line-height: 1.05;
		margin: 0 0 8px;
		font-variant-numeric: tabular-nums;
	}

	.project-impact-label {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		line-height: 1.4;
		margin: 0;
	}

	/* Two-column layout: body + sticky TOC */
	.project-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 200px;
		gap: 64px;
		margin: 0 0 64px;
	}

	.project-toc-cell {
		align-self: stretch;
	}

	.project-toc {
		position: sticky;
		top: 32px;
	}

	.project-toc-label {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-muted);
		margin: 0 0 12px;
	}

	.project-toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		border-left: 1px solid var(--border);
	}

	.project-toc-link {
		display: block;
		padding: 6px 14px;
		margin-left: -1px;
		border-left: 1px solid transparent;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast),
			border-color var(--transition-fast);
	}

	.project-toc-link:hover {
		color: var(--text-primary);
	}

	.project-toc-link.is-active {
		color: var(--text-primary);
		border-left-color: var(--text-accent);
		font-weight: 500;
	}

	/* Editorial body */
	.project-body {
		max-width: 720px;
	}

	.project-h2 {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-sm);
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--text-primary);
		margin: 48px 0 16px;
		scroll-margin-top: 32px;
	}

	.project-h2:first-child {
		margin-top: 0;
	}

	.project-prose {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		line-height: 1.65;
		color: var(--text-primary);
		margin: 0 0 16px;
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0 0 24px;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.project-list li {
		padding-left: 20px;
		position: relative;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		line-height: 1.6;
		color: var(--text-primary);
	}

	.project-list li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.75em;
