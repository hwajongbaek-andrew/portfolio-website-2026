---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { withBase } from "../../lib/base";
import ProjectCard from "../../components/ProjectCard.astro";

const facts = [
	{ label: "Year", value: "2021" },
	{ label: "Type", value: "Product design" },
	{ label: "Role", value: "Product designer" },
	{ label: "Tools", value: "Figma" },
];

const metrics = [
	{ value: "1M", label: "Daily TTC subway passengers" },
	{ value: "4", label: "Core features designed" },
	{ value: "2", label: "User personas guiding the design" },
	{ value: "100%", label: "Built on the familiar TTC map" },
];

const solutionFeatures = [
	{
		title: "Interactive subway map",
		text: "A fully interactive, intuitive map built on the official TTC map riders already know — reducing visual confusion from the start.",
	},
	{
		title: "Clear platform maps",
		text: "Visual maps for every platform, where a single tap tracks the user's location and surfaces the right exit.",
	},
	{
		title: "Visual content & info",
		text: "Real photos of exits and surrounding pathways, integrated with Google Maps for destination suggestions.",
	},
	{
		title: "Live alert system",
		text: "Real-time information on delays, service changes, and emergencies so riders avoid unexpected surprises.",
	},
];

const takeaways = [
	{
		title: "Personas surfaced real pain",
		text: "Persona-building and journey mapping pinned down the specific frustrations passengers face every day.",
	},
	{
		title: "Research finds the gap",
		text: "Effective market research was essential to identify where the design needed to focus.",
	},
	{
		title: "Clear maps win",
		text: "Clean visual maps for exits and pathways proved to be the critical success factor.",
	},
	{
		title: "Test, then iterate",
		text: "Closely monitored user testing is the next step to carry the concept forward.",
	},
];

const related = [
	{
		name: "Milkyway Glass",
		category: "E-commerce UX & retention",
		year: "2024",
		thumbnail: "/images/Laptop Mockup.png",
		thumbnailAlt: "Milkyway Glass on a laptop",
		videoSrc: "/videos/Portfolio-MK-Desktop.mp4",
		mockupAspect: "3750 / 2290",
		mockupMax: "94%",
		mockupOffsetY: "0px",
		screenTop: "3.2%",
		screenLeft: "7%",
		screenWidth: "86%",
		screenHeight: "93%",
		href: "/projects/milkyway-glass",
	},
	{
		name: "Seeders",
		category: "Multi-sided platform UX",
		year: "2021",
		thumbnail: "/images/Seeders_Mockup_E04.jpg",
		thumbnailAlt: "Seeders mobile app screens",
		href: "/projects/seeders",
	},
];
---

<DashboardLayout title="Exit Tracker — Andrew Baek">
	<a href={withBase("/projects")} class="project-breadcrumb">
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="19" y1="12" x2="5" y2="12"/>
			<polyline points="12 19 5 12 12 5"/>
		</svg>
		All projects
	</a>

	<!-- Header -->
	<header class="project-header">
		<p class="project-eyebrow">Product Design — Mobile App</p>
		<h1 class="project-title">Exit Tracker</h1>
		<p class="project-summary">
			A mobile app that helps subway riders find the exact exit they need —
			turning confusing underground stations into a clear path to the
			surface, and saving time on the way to a destination.
		</p>

		<ul class="project-facts">
			{facts.map((f) => (
				<li class="project-fact">
					<span class="project-fact-label">{f.label}</span>
					<span class="project-fact-value">{f.value}</span>
				</li>
			))}
		</ul>
	</header>

	<!-- Hero visual (styled placeholder — no source mockup available) -->
	<div class="project-hero">
		<div class="project-hero-device" aria-hidden="true">
			<div class="project-hero-notch"></div>
			<div class="project-hero-screen">
				<svg class="project-hero-map" viewBox="0 0 220 380" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
					<!-- transit lines -->
					<path d="M -10 120 H 230" stroke="#EAB308" stroke-width="6" stroke-linecap="round" fill="none"/>
					<path d="M 60 -10 V 390" stroke="#22C55E" stroke-width="6" stroke-linecap="round" fill="none"/>
					<path d="M 160 -10 V 390" stroke="#3B82F6" stroke-width="6" stroke-linecap="round" fill="none"/>
					<path d="M -10 260 H 230" stroke="#FB923C" stroke-width="6" stroke-linecap="round" fill="none"/>
					<!-- stations -->
					<circle cx="60" cy="120" r="7" fill="var(--bg-primary)" stroke="#1A1A1A" stroke-width="3"/>
					<circle cx="160" cy="120" r="7" fill="var(--bg-primary)" stroke="#1A1A1A" stroke-width="3"/>
					<circle cx="60" cy="260" r="7" fill="var(--bg-primary)" stroke="#1A1A1A" stroke-width="3"/>
					<circle cx="160" cy="260" r="7" fill="var(--bg-primary)" stroke="#1A1A1A" stroke-width="3"/>
				</svg>
				<div class="project-hero-pin">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
						<path d="M9 6l6 6-6 6"/>
						<line x1="3" y1="12" x2="15" y2="12"/>
					</svg>
					EXIT
				</div>
			</div>
		</div>
	</div>

	<!-- Impact / project at a glance -->
	<section class="project-impact">
		<h2 class="project-impact-title">At a glance</h2>
		<div class="project-impact-grid">
			{metrics.map((m) => (
				<div class="project-impact-card">
					<p class="project-impact-value">{m.value}</p>
					<p class="project-impact-label">{m.label}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Two-column body -->
	<div class="project-layout">
		<article class="project-body">
			<h2 class="project-h2" id="overview">Overview</h2>
			<p class="project-prose">
				Exit Tracker is a mobile app designed to help subway passengers
				navigate to the exit they actually need. By surfacing exit
				locations and the destinations each one leads to, it helps people
				reach where they're going without wasting time figuring out the
				station.
			</p>

			<h2 class="project-h2" id="challenge">The challenge</h2>
			<p class="project-prose">
				Subway passengers often struggle to find the correct exits because
				of unclear signage and complex underground pathways — which leads
				to confusion and delays. A close look surfaced four recurring pain
				points:
			</p>
			<ul class="project-list">
				<li><strong>Unclear signage</strong> makes the right direction hard to find.</li>
				<li><strong>Easy to get lost</strong> when you take the wrong exit.</li>
				<li><strong>Complex underground pathways</strong> overwhelm newcomers.</li>
				<li><strong>No intuitive map</strong> that includes the underground exits.</li>
			</ul>

			<h2 class="project-h2" id="process">Process</h2>
			<p class="project-prose">
				Market research framed the scale of the problem and who it affects
				most:
			</p>
			<ul class="project-list">
				<li><strong>1 million passengers</strong> ride the TTC subway, many through outdated stations.</li>
				<li><strong>Unclear signs and complex pathways</strong> make orientation hard.</li>
				<li><strong>Riders waste time</strong> figuring out directions instead of moving.</li>
			</ul>
			<p class="project-prose">Two personas kept the work grounded:</p>
			<ul class="project-list">
				<li><strong>Serena Green (student)</strong> — needs an easier map, an alert system, and self-explanatory signs; frustrated by unclear signs and confusing connections.</li>
				<li><strong>Martin Omar (software developer)</strong> — needs an extensive mobile map and clear exit signs; unfamiliar with the system and gets lost without one.</li>
			</ul>
			<p class="project-prose">
				From there I moved through site mapping to identify key functions,
				then wireframing and iteration on layouts and flows before
				committing to a high-fidelity design.
			</p>

			<figure class="project-figure project-figure--research">
				<div class="project-figure-frame" aria-hidden="true">
					<div class="project-figure-grid">
						<div class="project-figure-hot project-figure-hot-1"></div>
						<div class="project-figure-hot project-figure-hot-2"></div>
						<div class="project-figure-hot project-figure-hot-3"></div>
					</div>
					<span class="project-figure-tag">Insights · personas · site map</span>
				</div>
				<figcaption class="project-figure-caption">
					Research artifacts — market insights and personas that defined
					where riders get lost and what would help them most.
				</figcaption>
			</figure>

			<h2 class="project-h2" id="hmw">How might we</h2>
			<p class="project-prose">
				One question framed the design:
			</p>
			<ul class="project-list">
				<li>How might we <strong>reduce the confusion</strong> passengers feel when trying to find the right exit to reach their final destination?</li>
			</ul>

			<h2 class="project-h2" id="approach">The approach</h2>
			<p class="project-prose">
				Four features work together to make exits obvious and the journey
				predictable:
			</p>

			<figure class="project-figure project-figure--solution">
				<div class="project-figure-frame" aria-hidden="true">
					<div class="project-figure-screens">
						<div class="project-figure-screen project-figure-screen-1">
							<div class="project-figure-bar"></div>
							<div class="project-figure-block"></div>
							<div class="project-figure-block project-figure-block--sm"></div>
						</div>
						<div class="project-figure-screen project-figure-screen-2">
							<div class="project-figure-bar"></div>
							<div class="project-figure-cards">
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
							</div>
						</div>
						<div class="project-figure-screen project-figure-screen-3">
							<div class="project-figure-bar"></div>
							<div class="project-figure-cards">
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
							</div>
							<div class="project-figure-block project-figure-block--sm"></div>
						</div>
					</div>
					<span class="project-figure-tag">Map · platform view · alerts</span>
				</div>
				<figcaption class="project-figure-caption">
					Key screens — the interactive subway map, a tappable platform
					view with exit info, and the live alert feed.
				</figcaption>
			</figure>
			<div class="project-feature-grid">
				{solutionFeatures.map((f, i) => (
					<div class="project-feature">
						<span class="project-feature-index">{String(i + 1).padStart(2, "0")}</span>
						<div class="project-feature-text">
							<h3 class="project-feature-title">{f.title}</h3>
							<p class="project-feature-sub">{f.text}</p>
						</div>
					</div>
				))}
			</div>

			<h2 class="project-h2" id="outcomes">Outcomes</h2>
			<p class="project-prose">
				Exit Tracker came together as a clear concept for taking the guess
				work out of subway exits. As a concept project it has no deployment
				metrics yet, but it produced sharp takeaways for the next round:
			</p>

			<figure class="project-figure project-figure--results">
				<div class="project-figure-frame" aria-hidden="true">
					<svg class="project-figure-chart" viewBox="0 0 320 140" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
						<defs>
							<linearGradient id="exit-line-fill" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="currentColor" stop-opacity="0.28"/>
								<stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
							</linearGradient>
						</defs>
						<path d="M 0 100 L 320 96" stroke="currentColor" stroke-opacity="0.3" stroke-width="2" stroke-dasharray="4 4" fill="none"/>
						<path d="M 0 105 C 60 100, 120 80, 180 55 S 280 25, 320 18 L 320 140 L 0 140 Z" fill="url(#exit-line-fill)"/>
						<path d="M 0 105 C 60 100, 120 80, 180 55 S 280 25, 320 18" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"/>
					</svg>
					<span class="project-figure-tag">Clarity · confidence · time saved</span>
				</div>
				<figcaption class="project-figure-caption">
					A concept that trades underground confusion for a clear,
					map-led path to the right exit.
				</figcaption>
			</figure>
			<div class="project-feature-grid">
				{takeaways.map((t) => (
					<div class="project-feature">
						<div class="project-feature-text">
							<h3 class="project-feature-title">{t.title}</h3>
							<p class="project-feature-sub">{t.text}</p>
						</div>
					</div>
				))}
			</div>
		</article>

		<!-- Sticky table of contents -->
		<div class="project-toc-cell">
			<aside class="project-toc" aria-label="On this page">
				<p class="project-toc-label">On this page</p>
				<ul class="project-toc-list">
					<li><a href="#overview" class="project-toc-link" data-toc-link>Overview</a></li>
					<li><a href="#challenge" class="project-toc-link" data-toc-link>The challenge</a></li>
					<li><a href="#process" class="project-toc-link" data-toc-link>Process</a></li>
					<li><a href="#hmw" class="project-toc-link" data-toc-link>How might we</a></li>
					<li><a href="#approach" class="project-toc-link" data-toc-link>The approach</a></li>
					<li><a href="#outcomes" class="project-toc-link" data-toc-link>Outcomes</a></li>
				</ul>
			</aside>
		</div>
	</div>

	<!-- Related projects -->
	<section class="project-related">
		<div class="project-related-head">
			<h2 class="project-h2">More work</h2>
			<a href={withBase("/projects")} class="project-related-link">
				All projects
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"/>
					<polyline points="12 5 19 12 12 19"/>
				</svg>
			</a>
		</div>
		<div class="project-related-grid">
			{related.map((project) => <ProjectCard {...project} />)}
		</div>
	</section>
</DashboardLayout>

<style>
	/* Breadcrumb */
	.project-breadcrumb {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		margin-bottom: 32px;
		transition: color var(--transition-fast);
	}

	.project-breadcrumb:hover {
		color: var(--text-primary);
	}

	.project-breadcrumb svg {
		width: 14px;
		height: 14px;
	}

	/* Header */
	.project-header {
		margin-bottom: 56px;
	}

	.project-eyebrow {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-accent);
		margin: 0 0 12px;
	}

	.project-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: clamp(40px, 5vw, 64px);
		font-weight: 600;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--text-primary);
		margin: 0 0 20px;
	}

	.project-summary {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-lg);
		line-height: 1.5;
		color: var(--text-secondary);
		max-width: 640px;
		margin: 0 0 28px;
	}

	/* Facts as inline pills */
	.project-facts {
		list-style: none;
		padding: 0;
		margin: 0 0 12px;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.project-fact {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 6px 12px;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
	}

	.project-fact-label {
		color: var(--text-muted);
		font-weight: 500;
	}

	.project-fact-value {
		color: var(--text-primary);
		font-weight: 600;
	}

	/* Hero visual */
	.project-hero {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 10;
		border-radius: 24px;
		overflow: hidden;
		background: var(--accent-gradient, linear-gradient(to bottom, #F99E67, #FAB771));
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 64px;
	}

	/* Exit Tracker placeholder — a stylized phone showing a transit map */
	.project-hero-device {
		position: relative;
		width: 230px;
		max-width: 56%;
		aspect-ratio: 9 / 18;
		background: #1A1A1A;
		border-radius: 34px;
		padding: 10px;
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.22);
		transform: translateY(8px);
	}

	.project-hero-notch {
		position: absolute;
		top: 16px;
		left: 50%;
		transform: translateX(-50%);
		width: 64px;
		height: 6px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.35);
		z-index: 3;
	}

	.project-hero-screen {
		position: relative;
		width: 100%;
		height: 100%;
		border-radius: 26px;
		overflow: hidden;
		background: var(--bg-primary);
	}

	.project-hero-map {
		width: 100%;
		height: 100%;
		display: block;
	}

	.project-hero-pin {
		position: absolute;
		bottom: 18px;
		left: 50%;
		transform: translateX(-50%);
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 7px 14px;
		border-radius: 999px;
		background: var(--text-accent);
		color: #FFFFFF;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.08em;
		box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
	}

	/* Impact card section */
	.project-impact {
		margin-bottom: 64px;
	}

	.project-impact-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-muted);
		margin: 0 0 16px;
	}

	.project-impact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 16px;
	}

	.project-impact-card {
		padding: 24px 24px 22px;
		border: 1px solid var(--border);
		border-radius: 18px;
	}

	.project-impact-value {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-md);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--text-accent);
		line-height: 1.05;
		margin: 0 0 8px;
		font-variant-numeric: tabular-nums;
	}

	.project-impact-label {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		line-height: 1.4;
		margin: 0;
	}

	/* Two-column layout */
	.project-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 200px;
		gap: 64px;
		margin: 0 0 64px;
	}

	.project-toc-cell {
		align-self: stretch;
	}

	.project-toc {
		position: sticky;
		top: 32px;
	}

	.project-toc-label {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-muted);
		margin: 0 0 12px;
	}

	.project-toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		border-left: 1px solid var(--border);
	}

	.project-toc-link {
		display: block;
		padding: 6px 14px;
		margin-left: -1px;
		border-left: 1px solid transparent;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast),
			border-color var(--transition-fast);
	}

	.project-toc-link:hover {
		color: var(--text-primary);
	}

	.project-toc-link.is-active {
		color: var(--text-primary);
		border-left-color: var(--text-accent);
		font-weight: 500;
	}

	/* Editorial body */
	.project-body {
		max-width: 720px;
	}

	.project-h2 {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-sm);
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--text-primary);
		margin: 48px 0 16px;
		scroll-margin-top: 32px;
	}

	.project-h2:first-child {
		margin-top: 0;
	}

	.project-prose {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		line-height: 1.65;
		color: var(--text-primary);
		margin: 0 0 16px;
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0 0 24px;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.project-list li {
		padding-left: 20px;
		position: relative;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		line-height: 1.6;
		color: var(--text-primary);
	}

	.project-list li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.75em;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background-color: var(--text-accent);
	}

	.project-list strong {
		font-weight: 600;
	}

	/* Figure / visual placeholder blocks */
	.project-figure {
