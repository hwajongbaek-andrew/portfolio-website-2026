---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { withBase } from "../../lib/base";
import ProjectCard from "../../components/ProjectCard.astro";

const facts = [
	{ label: "Year", value: "2024" },
	{ label: "Type", value: "Website redesign" },
	{ label: "Role", value: "Lead product designer" },
	{ label: "Tools", value: "Figma, Wix, Shopify" },
];

const metrics = [
	{ value: "40–60%", label: "Monthly revenue lift" },
	{ value: "+58%", label: "Website visitors (145.8k)" },
	{ value: "+23%", label: "Page views (907.02k)" },
	{ value: "+38%", label: "Engagement (1m53s → 2m18s)" },
];

const baseline = [
	{ value: "1.6%", label: "Conversion rate" },
	{ value: "50%", label: "Bounce rate" },
	{ value: "1m 53s", label: "Avg engagement" },
];

const solutionFeatures = [
	{
		title: "Easier navigation",
		text: "Streamlined the nav bar and consolidated repeated content. Filters surfaced earlier so users got to product faster.",
	},
	{
		title: "Content placement",
		text: "Moved high-intent CTAs and key content above the fold for the majority of users who never scrolled further.",
	},
	{
		title: "Combo Creator",
		text: "Bundle-builder added to the homepage as a strategic AOV play, turning single-product sessions into multi-item baskets.",
	},
	{
		title: "Milkyway Rewards",
		text: "A dedicated loyalty program page designed to convert one-time buyers into returning customers through points + perks.",
	},
	{
		title: "UGC + influencer collaboration",
		text: "Integrated user-generated content and influencer features on the homepage to lift trust and broaden brand reach.",
	},
	{
		title: "Intuitive product filter",
		text: "Re-designed the filter system to be simpler and more direct, so users could narrow on what they actually wanted.",
	},
	{
		title: "SEO + mobile rebuild",
		text: "Applied SEO principles to every product description and rebuilt layouts mobile-first for the device most customers shop on.",
	},
];

const takeaways = [
	{
		title: "Enhanced user experience",
		text: "Putting user needs first led to a smoother, more engaging experience across devices.",
	},
	{
		title: "Strategic growth",
		text: "Mobile, SEO, and marketing collaboration combined into measurable business growth.",
	},
	{
		title: "Brand visibility",
		text: "Influencer and UGC collaborations elevated brand presence and broadened reach.",
	},
	{
		title: "Long-term impact",
		text: "The redesign laid a foundation for continued growth, not a one-time spike.",
	},
];

const related = [
	{
		name: "O3 Drinkware",
		category: "Brand-to-product commerce",
		year: "2024",
		thumbnail: "/images/RS-Mockup.png",
		thumbnailAlt: "O3 Drinkware on a desktop monitor",
		videoSrc: "/videos/O3-Portfolio-Front_A.mp4",
		mockupAspect: "3463 / 3083",
		screenTop: "3%",
		screenLeft: "3%",
		screenWidth: "94%",
		screenHeight: "65%",
		href: "/projects/o3-drinkware",
	},
	{
		name: "Seeders",
		category: "Multi-sided platform UX",
		year: "2021",
		thumbnail: "/images/Seeders_Mockup_E04.jpg",
		thumbnailAlt: "Seeders mobile app screens",
		href: "/projects/seeders",
	},
];
---

<DashboardLayout title="Milkyway Glass · Andrew Baek">
	<a href={withBase("/projects")} class="project-breadcrumb">
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="19" y1="12" x2="5" y2="12"/>
			<polyline points="12 19 5 12 12 5"/>
		</svg>
		All projects
	</a>

	<!-- Header: eyebrow, title, summary, inline facts & metric pills -->
	<header class="project-header">
		<p class="project-eyebrow">E-commerce UX & Retention Strategy</p>
		<h1 class="project-title">Milkyway Glass</h1>
		<p class="project-summary">
			A more enticing shopping experience built around data, SEO, and
			retention mechanics that lifted monthly revenue 40–60% and grew
			visitors 58%.
		</p>

		<ul class="project-facts">
			{facts.map((f) => (
				<li class="project-fact">
					<span class="project-fact-label">{f.label}</span>
					<span class="project-fact-value">{f.value}</span>
				</li>
			))}
		</ul>
	</header>

	<!-- Hero visual -->
	<div class="project-hero">
		<div class="project-hero-mockup">
			<img
				src={withBase("/images/Laptop Mockup.png")}
				alt="Milkyway Glass website preview on a laptop"
				class="project-hero-mockup-frame"
			/>
			<video
				class="project-hero-mockup-video"
				autoplay
				loop
				muted
				playsinline
				preload="metadata"
			>
				<source src={withBase("/videos/Portfolio-MK-Desktop.mp4")} type="video/mp4" />
			</video>
		</div>
	</div>

	<!-- Impact metrics - bigger card section after the hero -->
	<section class="project-impact">
		<h2 class="project-impact-title">Impact</h2>
		<div class="project-impact-grid">
			{metrics.map((m) => (
				<div class="project-impact-card">
					<p class="project-impact-value">{m.value}</p>
					<p class="project-impact-label">{m.label}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Two-column body: editorial prose + sticky TOC -->
	<div class="project-layout">
		<article class="project-body">
			<h2 class="project-h2" id="overview">Overview</h2>
			<p class="project-prose">
				Milkyway Glass is an e-commerce startup specializing in glass
				accessories for cannabis users. I led the redesign of their site
				by integrating data-driven insights, strategic SEO, and
				collaborative marketing work. The result was significant lift
				across visibility, navigation, and the overall customer
				experience, with a real increase in sales and engagement.
			</p>

			<h2 class="project-h2" id="problem">The problem</h2>
			<div class="project-callout">
				<span class="project-callout-label">The core problem</span>
				<p class="project-callout-text">
					Milkyway sold great glass, but the website got in the way.
					Confusing navigation, flat content, and a rough mobile
					experience were losing customers before they reached the cart.
				</p>
			</div>
			<p class="project-prose">And the numbers backed it up:</p>
			<div class="project-impact-grid">
				{baseline.map((b) => (
					<div class="project-impact-card project-impact-card--baseline">
						<p class="project-impact-value">{b.value}</p>
						<p class="project-impact-label">{b.label}</p>
					</div>
				))}
			</div>

			<h2 class="project-h2" id="challenge">The challenge</h2>
			<p class="project-prose">
				A close audit of the live site turned that into seven concrete
				issues, clustered around the three places users actually got stuck.
			</p>

			<div class="project-challenge">
				<!-- Old homepage -->
				<div class="project-challenge-row">
					<figure class="project-shot">
						<div class="project-shot-frame">
							<img
								class="project-shot-img"
								src={withBase("/images/milkyway-old-home.png")}
								alt="Original Milkyway Glass homepage with overloaded navigation, a promo banner, and dark category tiles"
								loading="lazy"
								onerror="this.remove()"
							/>
							<span class="project-shot-ph" aria-hidden="true">Old site · Home</span>
						</div>
						<figcaption class="project-shot-caption">
							Homepage: an overloaded Shop menu, a promo-driven CTA with
							unclear intent, and dark category tiles that were hard to read.
						</figcaption>
					</figure>
					<ul class="project-list">
						<li><strong>Complicated navigation.</strong> The Shop menu repeated the same categories, padding every path to a product.</li>
						<li><strong>Unclear calls to action.</strong> It wasn't obvious what would happen when a user clicked.</li>
						<li><strong>Outdated visuals</strong> with poor legibility, especially on smaller screens.</li>
					</ul>
				</div>

				<!-- Old shop / listing page -->
				<div class="project-challenge-row">
					<figure class="project-shot">
						<div class="project-shot-frame">
							<img
								class="project-shot-img"
								src={withBase("/images/milkyway-old-shop.png")}
								alt="Original Milkyway Glass shop page with a long filter sidebar and product cards without reviews"
								loading="lazy"
								onerror="this.remove()"
							/>
							<span class="project-shot-ph" aria-hidden="true">Old site · Shop</span>
						</div>
						<figcaption class="project-shot-caption">
							Shop: a long, non-collapsible filter that broke down on mobile,
							beside product cards with no reviews or ratings.
						</figcaption>
					</figure>
					<ul class="project-list">
						<li><strong>Complex product filters</strong> with no collapsible, mobile-friendly behaviour.</li>
						<li><strong>Sparse product information.</strong> Reviews and ratings were missing entirely.</li>
					</ul>
				</div>

				<!-- Old product detail page -->
				<div class="project-challenge-row">
					<figure class="project-shot">
						<div class="project-shot-frame">
							<img
								class="project-shot-img"
								src={withBase("/images/milkyway-old-product.png")}
								alt="Original Milkyway Glass product page with competing buttons and minimal supporting content"
								loading="lazy"
								onerror="this.remove()"
							/>
							<span class="project-shot-ph" aria-hidden="true">Old site · Product</span>
						</div>
						<figcaption class="project-shot-caption">
							Product page: competing buttons with no clear hierarchy by
							purpose, and little supporting content to drive a decision.
						</figcaption>
					</figure>
					<ul class="project-list">
						<li><strong>Disorganized layout</strong> with too many buttons fighting for attention.</li>
						<li><strong>No SEO foundation.</strong> Beyond the UX, the site was effectively invisible to search.</li>
					</ul>
				</div>
			</div>
			<h2 class="project-h2" id="process">Process</h2>
			<p class="project-prose">
				To avoid designing on gut, I anchored the work in three research
				methods that triangulated user behaviour, business context, and
				visual attention:
			</p>
			<ul class="project-list">
				<li>
					<strong>Heat maps and scroll maps</strong> to see where users
					actually clicked and how far they scrolled, separating
					real attention from assumed attention.
				</li>
				<li>
					<strong>User journey mapping</strong> from landing to checkout
					to find the specific moments where users dropped off.
				</li>
				<li>
					<strong>Marketing coordinator collaboration</strong> to pull
					traffic sources, campaign data, and competitive context, so
					design decisions stayed aligned with where customers were
					actually coming from.
				</li>
			</ul>
			<p class="project-prose">
				The data made the priorities undeniable: most sessions ended
				before the fold, mobile was where the majority of traffic lived,
				and the filter system was the single biggest abandonment point
				on the path to a product page.
			</p>

			<figure class="project-figure project-figure--research">
				<div class="project-figure-frame" aria-hidden="true">
					<div class="project-figure-grid">
						<div class="project-figure-hot project-figure-hot-1"></div>
						<div class="project-figure-hot project-figure-hot-2"></div>
						<div class="project-figure-hot project-figure-hot-3"></div>
					</div>
					<span class="project-figure-tag">Heat map · scroll depth · journey</span>
				</div>
				<figcaption class="project-figure-caption">
					Research artifacts: heat maps and scroll-depth maps revealed
					how shallow most sessions actually were on the original site.
				</figcaption>
			</figure>

			<h2 class="project-h2" id="hmw">How might we</h2>
			<p class="project-prose">
				Three guiding questions framed the work:
			</p>
			<ul class="project-list">
				<li>How might we <strong>simplify navigation</strong> to reduce friction for users?</li>
				<li>How might we <strong>strengthen customer connection</strong> through engaging content like loyalty, UGC, and influencer collaboration?</li>
				<li>How might we <strong>optimize the experience</strong> for mobile, where most shopping actually happens?</li>
			</ul>

			<h2 class="project-h2" id="approach">The approach</h2>
			<p class="project-prose">
				Seven interventions, each tied back to one of the three "How
				might we" questions:
			</p>

			<figure class="project-figure project-figure--solution">
				<div class="project-figure-frame" aria-hidden="true">
					<div class="project-figure-screens">
						<div class="project-figure-screen project-figure-screen-1">
							<div class="project-figure-bar"></div>
							<div class="project-figure-block"></div>
							<div class="project-figure-block project-figure-block--sm"></div>
						</div>
						<div class="project-figure-screen project-figure-screen-2">
							<div class="project-figure-bar"></div>
							<div class="project-figure-cards">
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
							</div>
						</div>
						<div class="project-figure-screen project-figure-screen-3">
							<div class="project-figure-bar"></div>
							<div class="project-figure-cards">
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
							</div>
							<div class="project-figure-block project-figure-block--sm"></div>
						</div>
					</div>
					<span class="project-figure-tag">Homepage · combo creator · product filter</span>
				</div>
				<figcaption class="project-figure-caption">
					Key screens from the rebuild: homepage hierarchy reset, the
					new Combo Creator, and the streamlined product filter.
				</figcaption>
			</figure>
			<div class="project-feature-grid">
				{solutionFeatures.map((f, i) => (
					<div class="project-feature">
						<span class="project-feature-index">{String(i + 1).padStart(2, "0")}</span>
						<div class="project-feature-text">
							<h3 class="project-feature-title">{f.title}</h3>
							<p class="project-feature-sub">{f.text}</p>
						</div>
					</div>
				))}
			</div>

			<h2 class="project-h2" id="outcomes">Outcomes</h2>
			<p class="project-prose">
				The redesign moved Milkyway from a static brand showcase to a
				measurable growth surface, and the wins compounded across four
				fronts:
			</p>

			<figure class="project-figure project-figure--results">
				<div class="project-figure-frame" aria-hidden="true">
					<svg class="project-figure-chart" viewBox="0 0 320 140" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
						<defs>
							<linearGradient id="mk-line-fill" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="currentColor" stop-opacity="0.28"/>
								<stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
							</linearGradient>
						</defs>
						<!-- Baseline (before) - flat dashed -->
						<path d="M 0 100 L 320 96" stroke="currentColor" stroke-opacity="0.3" stroke-width="2" stroke-dasharray="4 4" fill="none"/>
						<!-- Growth curve (after) - rising solid + filled area -->
						<path d="M 0 105 C 60 100, 120 80, 180 55 S 280 25, 320 18 L 320 140 L 0 140 Z" fill="url(#mk-line-fill)"/>
						<path d="M 0 105 C 60 100, 120 80, 180 55 S 280 25, 320 18" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"/>
					</svg>
					<span class="project-figure-tag">Revenue · visitors · engagement</span>
				</div>
				<figcaption class="project-figure-caption">
					Post-launch trends: sustained monthly growth across revenue,
					traffic, and engagement, not a single-week spike.
				</figcaption>
			</figure>
			<div class="project-feature-grid">
				{takeaways.map((t) => (
					<div class="project-feature">
						<div class="project-feature-text">
							<h3 class="project-feature-title">{t.title}</h3>
							<p class="project-feature-sub">{t.text}</p>
						</div>
					</div>
				))}
			</div>
		</article>

		<!-- Sticky table of contents (wrap pattern: outer cell stretches to grid row height, inner aside is the sticky element) -->
		<div class="project-toc-cell">
			<aside class="project-toc" aria-label="On this page">
				<p class="project-toc-label">On this page</p>
				<ul class="project-toc-list">
					<li><a href="#overview" class="project-toc-link" data-toc-link>Overview</a></li>
					<li><a href="#problem" class="project-toc-link" data-toc-link>The problem</a></li>
					<li><a href="#challenge" class="project-toc-link" data-toc-link>The challenge</a></li>
					<li><a href="#process" class="project-toc-link" data-toc-link>Process</a></li>
					<li><a href="#hmw" class="project-toc-link" data-toc-link>How might we</a></li>
					<li><a href="#approach" class="project-toc-link" data-toc-link>The approach</a></li>
					<li><a href="#outcomes" class="project-toc-link" data-toc-link>Outcomes</a></li>
				</ul>
			</aside>
		</div>
	</div>

	<!-- Related projects -->
	<section class="project-related">
		<div class="project-related-head">
			<h2 class="project-h2">More work</h2>
			<a href={withBase("/projects")} class="project-related-link">
				All projects
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"/>
					<polyline points="12 5 19 12 12 19"/>
				</svg>
			</a>
		</div>
		<div class="project-related-grid">
			{related.map((project) => <ProjectCard {...project} />)}
		</div>
	</section>
</DashboardLayout>

<style>
	/* Breadcrumb */
	.project-breadcrumb {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		margin-bottom: 32px;
		transition: color var(--transition-fast);
	}

	.project-breadcrumb:hover {
		color: var(--text-primary);
	}

	.project-breadcrumb svg {
		width: 14px;
		height: 14px;
	}

	/* Header */
	.project-header {
		margin-bottom: 56px;
	}

	.project-eyebrow {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-accent);
		margin: 0 0 12px;
	}

	.project-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: clamp(40px, 5vw, 64px);
		font-weight: 600;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--text-primary);
		margin: 0 0 20px;
	}

	.project-summary {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-lg);
		line-height: 1.5;
		color: var(--text-secondary);
		max-width: 640px;
		margin: 0 0 28px;
	}

	/* Facts as inline pills (the "specs" row) */
	.project-facts {
		list-style: none;
		padding: 0;
		margin: 0 0 12px;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.project-fact {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 6px 12px;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
	}

	.project-fact-label {
		color: var(--text-muted);
		font-weight: 500;
	}

	.project-fact-value {
		color: var(--text-primary);
		font-weight: 600;
	}

	/* Metric pills - same shape but accent-tinted */
	.project-metrics {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.project-metric {
		display: inline-flex;
		align-items: baseline;
		gap: 8px;
		padding: 6px 14px;
		border: 1px solid var(--text-accent);
		border-radius: 999px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
	}

	.project-metric-value {
		color: var(--text-accent);
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}

	.project-metric-label {
		color: var(--text-secondary);
	}

	/* Baseline metrics - muted, reflects "before" numbers in body */
	.project-metrics-baseline {
		margin: 16px 0 24px;
	}

	.project-metric-baseline {
		border-color: var(--border);
	}

	.project-metric-baseline .project-metric-value {
		color: var(--text-secondary);
	}

	/* Hero visual */
	.project-hero {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 10;
		border-radius: 24px;
		overflow: hidden;
		background: var(--accent-gradient, linear-gradient(to bottom, #F99E67, #FAB771));
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 64px;
	}

	.project-hero-mockup {
		position: relative;
		aspect-ratio: 3750 / 4906;
		max-width: 90%;
		/* Scaled up + shifted so the screen sits centred in the frame and the
		   keyboard is cropped out (translateY % is relative to the mockup). */
		max-height: 175%;
		transform: translateY(27%);
	}

	.project-hero-mockup-frame {
		position: relative;
		z-index: 1;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		pointer-events: none;
	}

	.project-hero-mockup-video {
		position: absolute;
		z-index: 2;
		top: 1.5%;
		left: 7%;
		width: 86%;
		height: 43.5%;
		object-fit: cover;
		display: block;
		border-radius: 4px;
	}

	/* Impact metric card section (between hero and body) */
	.project-impact {
		margin-bottom: 64px;
	}

	.project-impact-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-muted);
		margin: 0 0 16px;
	}

	.project-impact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 16px;
	}

	.project-impact-card {
		padding: 24px 24px 22px;
		border: 1px solid var(--border);
		border-radius: 18px;
	}

	.project-impact-value {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-md);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--text-accent);
