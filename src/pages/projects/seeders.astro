---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { withBase } from "../../lib/base";
import ProjectCard from "../../components/ProjectCard.astro";

const facts = [
	{ label: "Year", value: "2021" },
	{ label: "Type", value: "Product design" },
	{ label: "Role", value: "Product designer" },
	{ label: "Tools", value: "Figma" },
];

const metrics = [
	{ value: "5", label: "Features designed into one app" },
	{ value: "4", label: "Core functions unified" },
	{ value: "$600", label: "Annual value of urban gardening" },
	{ value: "2", label: "User personas guiding the design" },
];

const dimensions = [
	{ value: "01", label: "Affordance" },
	{ value: "02", label: "Constraint" },
	{ value: "03", label: "Accessibility" },
	{ value: "04", label: "Sustainability" },
	{ value: "05", label: "Joy / delight" },
];

const solutionFeatures = [
	{
		title: "Customizable favorites",
		text: "Users set preferred plants on their profile; favorites surface on the home screen for quick access to info and shopping.",
	},
	{
		title: "Unlimited planting information",
		text: "A searchable plant archive — the \"home gardening teacher\" — with detailed growing instructions and video tutorials.",
	},
	{
		title: "Intuitive shopping",
		text: "Self-explanatory, visually compelling product navigation with a seamless purchase path built into the main app.",
	},
	{
		title: "Community hub",
		text: "A familiar social network to share gardening stories and exchange, sell, or buy second-hand equipment.",
	},
	{
		title: "Smart scheduling",
		text: "A \"Today's Work\" feed delivers daily reminders so users stay aligned with their planting schedule.",
	},
];

const takeaways = [
	{
		title: "Customization is critical",
		text: "Gardening interests vary widely, so customizable features are what make the service genuinely useful and convenient.",
	},
	{
		title: "More research & testing",
		text: "Reaching a true all-in-one platform needs additional rounds of user research and testing before launch.",
	},
	{
		title: "Community needs safeguards",
		text: "Social and exchange features require extra planning to mitigate risks like fraud and privacy concerns.",
	},
];

const related = [
	{
		name: "Milkyway Glass",
		category: "E-commerce UX & retention",
		year: "2024",
		thumbnail: "/images/Laptop Mockup.png",
		thumbnailAlt: "Milkyway Glass on a laptop",
		videoSrc: "/videos/Portfolio-MK-Desktop.mp4",
		mockupAspect: "3750 / 2450",
		mockupMax: "94%",
		mockupOffsetY: "0px",
		screenTop: "3%",
		screenLeft: "7%",
		screenWidth: "86%",
		screenHeight: "87%",
		href: "/projects/milkyway-glass",
	},
	{
		name: "O3 Drinkware",
		category: "Brand-to-product commerce",
		year: "2024",
		thumbnail: "/images/RS-Mockup.png",
		thumbnailAlt: "O3 Drinkware on a desktop monitor",
		videoSrc: "/videos/O3-Portfolio-Front_A.mp4",
		mockupAspect: "3463 / 3083",
		screenTop: "3%",
		screenLeft: "3%",
		screenWidth: "94%",
		screenHeight: "65%",
		href: "/projects/o3-drinkware",
	},
];
---

<DashboardLayout title="Seeders — Andrew Baek">
	<a href={withBase("/projects")} class="project-breadcrumb">
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="19" y1="12" x2="5" y2="12"/>
			<polyline points="12 19 5 12 12 5"/>
		</svg>
		All projects
	</a>

	<!-- Header -->
	<header class="project-header">
		<p class="project-eyebrow">Product Design — Mobile App</p>
		<h1 class="project-title">Seeders</h1>
		<p class="project-summary">
			A next-gen gardening app for home gardeners — consolidating plant
			information, shopping, planning, and a second-hand community into one
			all-in-one experience, so people stop juggling multiple platforms.
		</p>

		<ul class="project-facts">
			{facts.map((f) => (
				<li class="project-fact">
					<span class="project-fact-label">{f.label}</span>
					<span class="project-fact-value">{f.value}</span>
				</li>
			))}
		</ul>
	</header>

	<!-- Hero visual (static mobile screens) -->
	<div class="project-hero">
		<img
			src={withBase("/images/Seeders_Mockup_E04.jpg")}
			alt="Seeders app shown across several mobile screens"
			class="project-hero-image"
		/>
	</div>

	<!-- Impact / project at a glance -->
	<section class="project-impact">
		<h2 class="project-impact-title">At a glance</h2>
		<div class="project-impact-grid">
			{metrics.map((m) => (
				<div class="project-impact-card">
					<p class="project-impact-value">{m.value}</p>
					<p class="project-impact-label">{m.label}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Two-column body -->
	<div class="project-layout">
		<article class="project-body">
			<h2 class="project-h2" id="overview">Overview</h2>
			<p class="project-prose">
				Seeders is an all-in-one gardening platform for home gardeners. It
				consolidates access to planting information, mobile shopping,
				gardening planning, and photo/equipment sharing into a single
				unified experience — eliminating the constant switching between
				separate apps and sites.
			</p>

			<h2 class="project-h2" id="challenge">The challenge</h2>
			<p class="project-prose">
				Home gardeners struggle to access comprehensive information, plan
				their efforts, and connect with others — often needing several
				platforms to cover one hobby. The core problem:
				<strong>home gardeners face challenges in accessing information,
				planning tools, and community engagement, frequently requiring
				multiple platforms to meet their needs.</strong>
			</p>
			<ul class="project-list">
				<li><strong>Hard to find reliable, plant-specific information.</strong></li>
				<li><strong>No intuitive scheduling tools</strong> to plan and stay on track.</li>
				<li><strong>Limited ways to share experiences</strong> with other gardeners.</li>
				<li><strong>Few platforms for second-hand equipment</strong> — buying or selling.</li>
				<li><strong>App fragmentation</strong> — needing many tools for one activity.</li>
			</ul>

			<h2 class="project-h2" id="process">Process</h2>
			<p class="project-prose">
				I ran both qualitative and quantitative research, analyzing the
				gardening context across five dimensions to keep the design
				grounded in real behaviour:
			</p>
			<ul class="project-metrics project-metrics-baseline">
				{dimensions.map((d) => (
					<li class="project-metric project-metric-baseline">
						<span class="project-metric-value">{d.value}</span>
						<span class="project-metric-label">{d.label}</span>
					</li>
				))}
			</ul>
			<p class="project-prose">
				A few insights shaped the direction: millennial participation in
				home gardening is rising, urban gardening can return roughly $600
				of value a year, it doubles as an educational tool for children,
				and it's an affordable long-term investment. I also built a User
				Interaction Analysis Map to trace how people complete gardening
				tasks and where friction shows up.
			</p>
			<ul class="project-list">
				<li><strong>Jennifer Owens (hotel receptionist)</strong> — wants a gardening community with a used-item sharing platform and an accessible, affordable shop.</li>
				<li><strong>Adriana Lopez (school teacher)</strong> — wants consolidation: an intuitive mobile shop, a customizable planner, and one integrated all-in-one app.</li>
			</ul>

			<figure class="project-figure project-figure--research">
				<div class="project-figure-frame" aria-hidden="true">
					<div class="project-figure-grid">
						<div class="project-figure-hot project-figure-hot-1"></div>
						<div class="project-figure-hot project-figure-hot-2"></div>
						<div class="project-figure-hot project-figure-hot-3"></div>
					</div>
					<span class="project-figure-tag">5 dimensions · personas · interaction map</span>
				</div>
				<figcaption class="project-figure-caption">
					Research artifacts — a five-dimension analysis and a user
					interaction map that exposed where gardeners get stuck.
				</figcaption>
			</figure>

			<h2 class="project-h2" id="hmw">How might we</h2>
			<p class="project-prose">
				One question anchored the product:
			</p>
			<ul class="project-list">
				<li>How might we provide an extensive gardening experience — <strong>shopping, planning, and socializing</strong> — through an informative community hub in a single digital environment?</li>
			</ul>

			<h2 class="project-h2" id="approach">The approach</h2>
			<p class="project-prose">
				Site mapping identified four core functions — plant search,
				commerce, community, and calendar — which wireframing turned into
				five connected features:
			</p>

			<figure class="project-figure project-figure--solution">
				<div class="project-figure-frame" aria-hidden="true">
					<div class="project-figure-screens">
						<div class="project-figure-screen project-figure-screen-1">
							<div class="project-figure-bar"></div>
							<div class="project-figure-block"></div>
							<div class="project-figure-block project-figure-block--sm"></div>
						</div>
						<div class="project-figure-screen project-figure-screen-2">
							<div class="project-figure-bar"></div>
							<div class="project-figure-cards">
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
							</div>
						</div>
						<div class="project-figure-screen project-figure-screen-3">
							<div class="project-figure-bar"></div>
							<div class="project-figure-cards">
								<div class="project-figure-card"></div>
								<div class="project-figure-card"></div>
							</div>
							<div class="project-figure-block project-figure-block--sm"></div>
						</div>
					</div>
					<span class="project-figure-tag">Search · shop · community · calendar</span>
				</div>
				<figcaption class="project-figure-caption">
					Key screens — favorites and plant info, the in-app shop, the
					second-hand community, and the daily planting schedule.
				</figcaption>
			</figure>
			<div class="project-feature-grid">
				{solutionFeatures.map((f, i) => (
					<div class="project-feature">
						<span class="project-feature-index">{String(i + 1).padStart(2, "0")}</span>
						<div class="project-feature-text">
							<h3 class="project-feature-title">{f.title}</h3>
							<p class="project-feature-sub">{f.text}</p>
						</div>
					</div>
				))}
			</div>

			<h2 class="project-h2" id="outcomes">Outcomes</h2>
			<p class="project-prose">
				Seeders landed as a cohesive concept for a single gardening home
				base. This was a concept project, so there are no deployment
				metrics yet — but the work produced clear takeaways for taking it
				further:
			</p>

			<figure class="project-figure project-figure--results">
				<div class="project-figure-frame" aria-hidden="true">
					<svg class="project-figure-chart" viewBox="0 0 320 140" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
						<defs>
							<linearGradient id="seeders-line-fill" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="currentColor" stop-opacity="0.28"/>
								<stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
							</linearGradient>
						</defs>
						<path d="M 0 100 L 320 96" stroke="currentColor" stroke-opacity="0.3" stroke-width="2" stroke-dasharray="4 4" fill="none"/>
						<path d="M 0 105 C 60 100, 120 80, 180 55 S 280 25, 320 18 L 320 140 L 0 140 Z" fill="url(#seeders-line-fill)"/>
						<path d="M 0 105 C 60 100, 120 80, 180 55 S 280 25, 320 18" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"/>
					</svg>
					<span class="project-figure-tag">Consolidation · customization · community</span>
				</div>
				<figcaption class="project-figure-caption">
					A unified concept that replaces a fragmented toolset with one
					customizable, community-driven gardening app.
				</figcaption>
			</figure>
			<div class="project-feature-grid">
				{takeaways.map((t) => (
					<div class="project-feature">
						<div class="project-feature-text">
							<h3 class="project-feature-title">{t.title}</h3>
							<p class="project-feature-sub">{t.text}</p>
						</div>
					</div>
				))}
			</div>
		</article>

		<!-- Sticky table of contents -->
		<div class="project-toc-cell">
			<aside class="project-toc" aria-label="On this page">
				<p class="project-toc-label">On this page</p>
				<ul class="project-toc-list">
					<li><a href="#overview" class="project-toc-link" data-toc-link>Overview</a></li>
					<li><a href="#challenge" class="project-toc-link" data-toc-link>The challenge</a></li>
					<li><a href="#process" class="project-toc-link" data-toc-link>Process</a></li>
					<li><a href="#hmw" class="project-toc-link" data-toc-link>How might we</a></li>
					<li><a href="#approach" class="project-toc-link" data-toc-link>The approach</a></li>
					<li><a href="#outcomes" class="project-toc-link" data-toc-link>Outcomes</a></li>
				</ul>
			</aside>
		</div>
	</div>

	<!-- Related projects -->
	<section class="project-related">
		<div class="project-related-head">
			<h2 class="project-h2">More work</h2>
			<a href={withBase("/projects")} class="project-related-link">
				All projects
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"/>
					<polyline points="12 5 19 12 12 19"/>
				</svg>
			</a>
		</div>
		<div class="project-related-grid">
			{related.map((project) => <ProjectCard {...project} />)}
		</div>
	</section>
</DashboardLayout>

<style>
	/* Breadcrumb */
	.project-breadcrumb {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		margin-bottom: 32px;
		transition: color var(--transition-fast);
	}

	.project-breadcrumb:hover {
		color: var(--text-primary);
	}

	.project-breadcrumb svg {
		width: 14px;
		height: 14px;
	}

	/* Header */
	.project-header {
		margin-bottom: 56px;
	}

	.project-eyebrow {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-accent);
		margin: 0 0 12px;
	}

	.project-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: clamp(40px, 5vw, 64px);
		font-weight: 600;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--text-primary);
		margin: 0 0 20px;
	}

	.project-summary {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-lg);
		line-height: 1.5;
		color: var(--text-secondary);
		max-width: 640px;
		margin: 0 0 28px;
	}

	/* Facts as inline pills */
	.project-facts {
		list-style: none;
		padding: 0;
		margin: 0 0 12px;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.project-fact {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 6px 12px;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
	}

	.project-fact-label {
		color: var(--text-muted);
		font-weight: 500;
	}

	.project-fact-value {
		color: var(--text-primary);
		font-weight: 600;
	}

	/* Metric pills */
	.project-metrics {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.project-metric {
		display: inline-flex;
		align-items: baseline;
		gap: 8px;
		padding: 6px 14px;
		border: 1px solid var(--text-accent);
		border-radius: 999px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
	}

	.project-metric-value {
		color: var(--text-accent);
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}

	.project-metric-label {
		color: var(--text-secondary);
	}

	.project-metrics-baseline {
		margin: 16px 0 24px;
	}

	.project-metric-baseline {
		border-color: var(--border);
	}

	.project-metric-baseline .project-metric-value {
		color: var(--text-secondary);
	}

	/* Hero visual */
	.project-hero {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 10;
		border-radius: 24px;
		overflow: hidden;
		background: var(--accent-gradient, linear-gradient(to bottom, #F99E67, #FAB771));
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 64px;
	}

	/* Seeders hero is a static image of the app screens */
	.project-hero-image {
		max-width: 92%;
		max-height: 100%;
		object-fit: contain;
		display: block;
	}

	/* Impact card section */
	.project-impact {
		margin-bottom: 64px;
	}

	.project-impact-title {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-muted);
		margin: 0 0 16px;
	}

	.project-impact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 16px;
	}

	.project-impact-card {
		padding: 24px 24px 22px;
		border: 1px solid var(--border);
		border-radius: 18px;
	}

	.project-impact-value {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-md);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--text-accent);
		line-height: 1.05;
		margin: 0 0 8px;
		font-variant-numeric: tabular-nums;
	}

	.project-impact-label {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		line-height: 1.4;
		margin: 0;
	}

	/* Two-column layout */
	.project-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 200px;
		gap: 64px;
		margin: 0 0 64px;
	}

	.project-toc-cell {
		align-self: stretch;
	}

	.project-toc {
		position: sticky;
		top: 32px;
	}

	.project-toc-label {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-muted);
		margin: 0 0 12px;
	}

	.project-toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		border-left: 1px solid var(--border);
	}

	.project-toc-link {
		display: block;
		padding: 6px 14px;
		margin-left: -1px;
		border-left: 1px solid transparent;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast),
			border-color var(--transition-fast);
	}

	.project-toc-link:hover {
		color: var(--text-primary);
	}

	.project-toc-link.is-active {
		color: var(--text-primary);
		border-left-color: var(--text-accent);
		font-weight: 500;
	}

	/* Editorial body */
	.project-body {
		max-width: 720px;
	}

	.project-h2 {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-display-sm);
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--text-primary);
		margin: 48px 0 16px;
		scroll-margin-top: 32px;
	}

	.project-h2:first-child {
		margin-top: 0;
	}

	.project-prose {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		line-height: 1.65;
		color: var(--text-primary);
		margin: 0 0 16px;
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0 0 24px;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.project-list li {
		padding-left: 20px;
		position: relative;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		line-height: 1.6;
		color: var(--text-primary);
	}

	.project-list li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.75em;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background-color: var(--text-accent);
	}

	.project-list strong {
		font-weight: 600;
	}

	/* Figure / visual placeholder blocks */
	.project-figure {
		margin: 32px 0 8px;
	}

	.project-figure-frame {
		position: relative;
		aspect-ratio: 16 / 9;
		border-radius: 18px;
		border: 1px solid var(--border);
		background: linear-gradient(135deg, rgba(229, 167, 122, 0.12), rgba(229, 167, 122, 0.04));
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px;
	}

	:global([data-theme="dark"]) .project-figure-frame {
		background: linear-gradient(135deg, rgba(251, 146, 60, 0.10), rgba(251, 146, 60, 0.02));
	}

	.project-figure-tag {
		position: absolute;
		bottom: 14px;
		left: 16px;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 10px;
		font-weight: 600;
