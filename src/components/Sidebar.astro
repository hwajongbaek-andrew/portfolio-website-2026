---
import ThemeToggle from "./ThemeToggle.astro";
import { withBase } from "../lib/base";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
let pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
if (base && pathname.startsWith(base)) pathname = pathname.slice(base.length) || "/";

const logoMask = `-webkit-mask-image:url(${withBase("/images/logo.svg")});mask-image:url(${withBase("/images/logo.svg")})`;

const primaryNav = [
	{ label: "Home", href: "/", shortcut: "1", icon: "compass" },
	{ label: "Projects", href: "/projects", shortcut: "2", icon: "flag" },
	{ label: "Stack", href: "/stack", shortcut: "3", icon: "stack" },
	{ label: "About", href: "/about", shortcut: "4", icon: "user" },
];

const connectNav = [
	{ label: "Contact", href: "/contact", shortcut: "C", icon: "mail", external: false },
	{ label: "LinkedIn", href: "https://www.linkedin.com/in/andrew-baek-a29388202/", shortcut: null, icon: "linkedin", external: true },
	{ label: "Instagram", href: "https://www.instagram.com/andrew__baek/", shortcut: null, icon: "instagram", external: true },
];

const isActive = (href: string) => {
	if (href === "/") return pathname === "/";
	return pathname === href || pathname.startsWith(href + "/");
};
---

<aside class="sidebar">
	<!-- Collapse / expand toggle — pinned just outside the sidebar's right edge -->
	<button
		type="button"
		class="sidebar-toggle"
		data-sidebar-toggle
		aria-label="Collapse sidebar"
		aria-expanded="true"
	>
		<svg class="sidebar-toggle-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<polyline points="15 18 9 12 15 6"/>
		</svg>
	</button>

	<!-- Identity: full wordmark when expanded, monogram when collapsed -->
	<a href={withBase("/")} class="sidebar-identity" aria-label="Andrew Baek, home">
		<span class="sidebar-monogram" aria-hidden="true">AB</span>
		<span class="sidebar-wordmark">
			<span class="sidebar-logo" role="img" aria-label="Andrew Baek" style={logoMask}></span>
			<span class="sidebar-role">Product Designer</span>
		</span>
	</a>

	<!-- Primary nav -->
	<nav class="sidebar-section" aria-label="Primary">
		<ul class="sidebar-list">
			{primaryNav.map((item) => (
				<li>
					<a
						href={withBase(item.href)}
						class:list={["sidebar-item", { "is-active": isActive(item.href) }]}
					>
						<span class="sidebar-icon" aria-hidden="true">
							{item.icon === "compass" && (
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="9"/>
									<polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
								</svg>
							)}
							{item.icon === "flag" && (
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
									<line x1="4" y1="22" x2="4" y2="15"/>
								</svg>
							)}
							{item.icon === "user" && (
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
									<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
									<circle cx="12" cy="7" r="4"/>
								</svg>
							)}
							{item.icon === "stack" && (
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
									<polygon points="12 2 2 7 12 12 22 7 12 2"/>
									<polyline points="2 17 12 22 22 17"/>
									<polyline points="2 12 12 17 22 12"/>
								</svg>
							)}
						</span>
						<span class="sidebar-label">{item.label}</span>
						<span class="sidebar-tooltip" role="tooltip">{item.label}</span>
					</a>
				</li>
			))}
		</ul>
	</nav>

	<!-- Connect -->
	<div class="sidebar-section">
		<p class="sidebar-section-label">Connect</p>
		<ul class="sidebar-list">
			{connectNav.map((item) => (
				<li>
					<a
						href={withBase(item.href)}
						target={item.external ? "_blank" : undefined}
						rel={item.external ? "noopener noreferrer" : undefined}
						class:list={["sidebar-item", { "is-active": !item.external && isActive(item.href) }]}
					>
						<span class="sidebar-icon" aria-hidden="true">
							{item.icon === "mail" && (
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
									<polyline points="22,6 12,13 2,6"/>
								</svg>
							)}
							{item.icon === "instagram" && (
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
									<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
									<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
								</svg>
							)}
							{item.icon === "linkedin" && (
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none">
									<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
								</svg>
							)}
						</span>
						<span class="sidebar-label">{item.label}</span>
						{item.external && (
							<span class="sidebar-shortcut sidebar-shortcut-external" aria-hidden="true">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<line x1="7" y1="17" x2="17" y2="7"/>
									<polyline points="7 7 17 7 17 17"/>
								</svg>
							</span>
						)}
						<span class="sidebar-tooltip" role="tooltip">{item.label}</span>
					</a>
				</li>
			))}
		</ul>
	</div>

	<!-- Bottom: status + theme toggle (label when expanded, tooltip when collapsed) -->
	<div class="sidebar-bottom">
		<div class="sidebar-status">
			<span class="sidebar-status-dot" aria-hidden="true"></span>
			<span class="sidebar-status-text">Currently @ MedMe Health</span>
		</div>
		<div class="sidebar-theme">
			<span class="sidebar-theme-label">Theme</span>
			<ThemeToggle />
			<span class="sidebar-tooltip" role="tooltip">Toggle theme</span>
		</div>
	</div>
</aside>

<style>
	.sidebar {
		position: fixed;
		top: 16px;
		left: 16px;
		bottom: 16px;
		width: var(--sidebar-w, 280px);
		/* Shared square footprint for the brand mark + nav icons when collapsed */
		--rail-slot: 40px;
		padding: 28px 20px 20px;
		display: flex;
		flex-direction: column;
		background-color: var(--bg-primary);
		border: 1px solid var(--border);
		/* Match the project-card corner radius for a cohesive language */
		border-radius: 20px;
		transition: width 320ms cubic-bezier(0.4, 0, 0.2, 1),
			padding 320ms cubic-bezier(0.4, 0, 0.2, 1),
			background-color 300ms ease, border-color 300ms ease;
		z-index: 50;
	}

	:global([data-sidebar="collapsed"]) .sidebar {
		padding-left: 16px;
		padding-right: 16px;
	}

	/* Collapse / expand toggle — a "bookmark" tab attached to the sidebar's
	   outer right edge. left: 100% keeps it fully outside the bounding box so
	   it never overlaps internal content; the left side is flush (no border /
	   no radius) and the right side is rounded like a tab. */
	.sidebar-toggle {
		position: absolute;
		top: 50%;
		left: 100%;
		transform: translateY(-50%);
		width: 24px;
		height: 56px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: 1px solid var(--border);
		border-left: none;
		border-radius: 0 12px 12px 0;
		background-color: var(--bg-primary);
		color: var(--text-secondary);
		cursor: pointer;
		z-index: 60;
		transition: background-color var(--transition-fast),
			color var(--transition-fast), border-color var(--transition-fast);
	}

	.sidebar-toggle:hover {
		background-color: var(--bg-secondary);
		color: var(--text-primary);
		border-color: var(--text-muted);
	}

	.sidebar-toggle-icon {
		transition: transform 320ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	:global([data-sidebar="collapsed"]) .sidebar-toggle-icon {
		transform: rotate(180deg);
	}

	/* Identity block: logo wordmark + role */
	.sidebar-identity {
		display: flex;
		flex-direction: column;
		gap: 8px;
		padding: 4px 10px;
		text-decoration: none;
		color: inherit;
		border-radius: 12px;
		margin-bottom: 32px;
	}

	:global([data-sidebar="collapsed"]) .sidebar-identity {
		padding: 0;
		align-items: center;
	}

	.sidebar-wordmark {
		display: flex;
		flex-direction: column;
		gap: 8px;
		min-width: 0;
		opacity: 1;
		transition: opacity 200ms ease;
	}

	:global([data-sidebar="collapsed"]) .sidebar-wordmark {
		display: none;
	}

	/* Monogram chip — shown only when collapsed.
	   Shares the exact --rail-slot box with the collapsed nav icons so the
	   brand mark and every icon center on the same vertical axis. */
	.sidebar-monogram {
		display: none;
		width: var(--rail-slot, 40px);
		height: var(--rail-slot, 40px);
		flex-shrink: 0;
		align-items: center;
		justify-content: center;
		border-radius: 11px;
		background: var(--accent-gradient, linear-gradient(to bottom, #F99E67, #FAB771));
		color: #FFFFFF;
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 15px;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	:global([data-sidebar="collapsed"]) .sidebar-monogram {
		display: flex;
	}

	.sidebar-logo {
		display: block;
		width: 100%;
		max-width: 180px;
		aspect-ratio: 1630.06 / 150;
		background-color: var(--text-accent);
		/* mask-image is set inline (base-aware) via the `logoMask` style */
		-webkit-mask-repeat: no-repeat;
		-webkit-mask-position: center;
		-webkit-mask-size: contain;
		mask-repeat: no-repeat;
		mask-position: center;
		mask-size: contain;
		transition: background-color 300ms ease;
	}

	.sidebar-role {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 12px;
		color: var(--text-secondary);
		line-height: 1.2;
	}

	/* Sections */
	.sidebar-section {
		margin-bottom: 8px;
	}

	.sidebar-section-label {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--text-muted);
		margin: 24px 10px 8px;
	}

	.sidebar-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	/* Nav item */
	.sidebar-item {
		position: relative;
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 8px 10px;
		border-radius: 10px;
		text-decoration: none;
		color: var(--text-secondary);
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 500;
		transition: background-color var(--transition-fast), color var(--transition-fast);
	}

	.sidebar-item:hover {
		background-color: var(--bg-secondary);
		color: var(--text-primary);
	}

	.sidebar-item.is-active {
		background-color: var(--bg-secondary);
		color: var(--text-primary);
	}

	.sidebar-icon {
		width: 18px;
		height: 18px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		color: currentColor;
	}

	.sidebar-icon svg {
		width: 100%;
		height: 100%;
	}

	.sidebar-label {
		flex: 1;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		opacity: 1;
		transition: opacity 180ms ease;
	}

	/* Tooltip — hidden by default, only revealed on hover when collapsed */
	.sidebar-tooltip {
		position: absolute;
		left: calc(100% + 14px);
		top: 50%;
		transform: translateY(-50%) translateX(-4px);
		padding: 6px 10px;
		border-radius: 8px;
		background-color: var(--text-primary);
		color: var(--bg-primary);
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 12px;
		font-weight: 500;
		white-space: nowrap;
		pointer-events: none;
		opacity: 0;
		visibility: hidden;
		z-index: 70;
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
		transition: opacity 160ms ease, transform 160ms ease, visibility 160ms;
	}

	.sidebar-tooltip::before {
		content: "";
		position: absolute;
		top: 50%;
		left: -4px;
		width: 8px;
		height: 8px;
		transform: translateY(-50%) rotate(45deg);
		background-color: var(--text-primary);
		border-radius: 1px;
	}

	/* Tooltips activate only in the collapsed state */
	:global([data-sidebar="collapsed"]) .sidebar-item:hover .sidebar-tooltip,
	:global([data-sidebar="collapsed"]) .sidebar-item:focus-visible .sidebar-tooltip,
	:global([data-sidebar="collapsed"]) .sidebar-theme:hover .sidebar-tooltip,
	:global([data-sidebar="collapsed"]) .sidebar-theme:focus-within .sidebar-tooltip {
		opacity: 1;
		visibility: visible;
		transform: translateY(-50%) translateX(0);
	}

	/* ---- Collapsed state: icons only ---- */
	:global([data-sidebar="collapsed"]) .sidebar-item {
		width: var(--rail-slot, 40px);
		height: var(--rail-slot, 40px);
		margin-inline: auto;
		justify-content: center;
		gap: 0;
		padding: 0;
	}

	:global([data-sidebar="collapsed"]) .sidebar-label,
	:global([data-sidebar="collapsed"]) .sidebar-shortcut {
		opacity: 0;
		width: 0;
		min-width: 0;
		margin: 0;
		flex: 0 0 0;
		overflow: hidden;
		pointer-events: none;
	}

	.sidebar-shortcut {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 11px;
		font-weight: 500;
		color: var(--text-muted);
		font-variant-numeric: tabular-nums;
		min-width: 16px;
		text-align: center;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.sidebar-shortcut-external {
		width: 14px;
		height: 14px;
	}

	.sidebar-shortcut-external svg {
		width: 100%;
		height: 100%;
		color: var(--text-muted);
	}

	/* Bottom */
	.sidebar-bottom {
		margin-top: auto;
		padding-top: 24px;
		border-top: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		gap: 16px;
		transition: border-color 300ms ease;
	}

	.sidebar-status {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 0 10px;
	}

	.sidebar-status-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background-color: #22c55e;
		box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.15);
		flex-shrink: 0;
	}

	.sidebar-status-text {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 12px;
		font-weight: 500;
		color: var(--text-secondary);
	}

	/* Theme row: label + switch when expanded; centred switch + tooltip when collapsed */
	.sidebar-theme {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 0 10px;
	}

	.sidebar-theme-label {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		font-weight: 500;
		color: var(--text-secondary);
	}

	:global([data-sidebar="collapsed"]) .sidebar-theme {
		justify-content: center;
		padding: 0;
	}

	:global([data-sidebar="collapsed"]) .sidebar-theme-label {
		display: none;
	}

	/* Collapsed: section label becomes a hairline divider */
	:global([data-sidebar="collapsed"]) .sidebar-section-label {
		font-size: 0;
		color: transparent;
		height: 1px;
		margin: 16px 8px 12px;
		padding: 0;
		background-color: var(--border);
		overflow: hidden;
	}

	/* Collapsed: hide the status row (incl. the green dot) entirely */
	:global([data-sidebar="collapsed"]) .sidebar-status {
		display: none;
	}

	/* Collapsed: keep the theme toggle, but flip it to a vertical pill so it
	   fits the narrow rail. Both data-sidebar and data-theme live on <html>,
	   so the dark-state thumb position can be derived from the same element.
	   The leading `html` raises specificity above ThemeToggle's own rules. */
	:global(html[data-sidebar="collapsed"] .theme-toggle) {
		width: 40px;
		height: 74px;
		margin-inline: auto;
	}

	:global(html[data-sidebar="collapsed"] .toggle-thumb) {
		top: 4px;
		left: 50%;
		transform: translateX(-50%);
	}

	:global(html[data-sidebar="collapsed"][data-theme="dark"] .toggle-thumb) {
		transform: translateX(-50%) translateY(32px);
	}

	@media (max-width: 768px) {
		.sidebar {
			display: none;
		}
	}
</style>

<script>
	const STORAGE_KEY = "sidebar";
	const root = document.documentElement;

	const apply = (collapsed: boolean) => {
		root.setAttribute("data-sidebar", collapsed ? "collapsed" : "expanded");
		document.querySelectorAll<HTMLButtonElement>("[data-sidebar-toggle]").forEach((btn) => {
			btn.setAttribute("aria-expanded", collapsed ? "false" : "true");
			btn.setAttribute(
				"aria-label",
				collapsed ? "Expand sidebar" : "Collapse sidebar"
			);
		});
	};

	// Sync initial button state with the attribute set pre-paint in the layout head.
	apply(root.getAttribute("data-sidebar") === "collapsed");

	document.querySelectorAll<HTMLButtonElement>("[data-sidebar-toggle]").forEach((btn) => {
		btn.addEventListener("click", () => {
			const collapsed = root.getAttribute("data-sidebar") !== "collapsed";
			apply(collapsed);
			try {
				localStorage.setItem(STORAGE_KEY, collapsed ? "collapsed" : "expanded");
			} catch {}
		});
	});
</script>
