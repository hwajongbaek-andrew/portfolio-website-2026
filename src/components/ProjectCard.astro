---
interface Props {
	name: string;
	category: string;
	year: string;
	thumbnail?: string;
	thumbnailAlt?: string;
	href?: string;
}

const {
	name,
	category,
	year,
	thumbnail,
	thumbnailAlt = "",
	href = "#",
} = Astro.props;
---

<a href={href} class="project-card">
	<div class="project-card-thumb">
		{thumbnail ? (
			<img src={thumbnail} alt={thumbnailAlt} loading="lazy" />
		) : (
			<div class="project-card-placeholder" aria-hidden="true"></div>
		)}
	</div>
	<div class="project-card-body">
		<div class="project-card-text">
			<p class="project-card-name">{name}</p>
			<p class="project-card-category">{category}</p>
		</div>
		<span class="project-card-year">{year}</span>
	</div>
</a>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--border);
		border-radius: 20px;
		background-color: var(--bg-primary);
		text-decoration: none;
		overflow: hidden;
		transition: border-color var(--transition-fast),
			transform var(--transition-fast);
	}

	.project-card:hover {
		border-color: var(--text-muted);
		transform: translateY(-2px);
	}

	.project-card-thumb {
		aspect-ratio: 16 / 10;
		width: 100%;
		overflow: hidden;
		background: var(--accent-gradient, linear-gradient(to bottom, #F99E67, #FAB771));
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.project-card-thumb img {
		width: 88%;
		height: 88%;
		object-fit: contain;
		display: block;
	}

	.project-card-placeholder {
		width: 100%;
		height: 100%;
	}

	.project-card-body {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		padding: 16px 20px 18px;
	}

	.project-card-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.project-card-name {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.3;
	}

	.project-card-category {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.3;
	}

	.project-card-year {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 12px;
		font-weight: 500;
		color: var(--text-secondary);
		padding: 4px 10px;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-variant-numeric: tabular-nums;
		flex-shrink: 0;
		white-space: nowrap;
	}
</style>
