---
import { withBase } from "../lib/base";

interface Props {
	name: string;
	category: string;
	year: string;
	thumbnail?: string;
	thumbnailAlt?: string;
	videoSrc?: string;
	mockupAspect?: string;
	mockupMax?: string; // e.g., "100%" or "120%" — overrides default 92%
	mockupOffsetY?: string; // e.g., "50px" — shifts mockup down inside the thumb
	screenTop?: string;
	screenLeft?: string;
	screenWidth?: string;
	screenHeight?: string;
	href?: string;
}

const {
	name,
	category,
	year,
	thumbnail,
	thumbnailAlt = "",
	videoSrc,
	mockupAspect,
	mockupMax,
	mockupOffsetY,
	screenTop,
	screenLeft,
	screenWidth,
	screenHeight,
	href = "#",
} = Astro.props;

const useMockupCombo = !!(videoSrc && thumbnail && mockupAspect);

const mockupStyle: Record<string, string> = {};
if (mockupAspect) mockupStyle["aspectRatio"] = mockupAspect;
if (mockupMax) mockupStyle["--mockup-max"] = mockupMax;
if (mockupOffsetY) mockupStyle["--mockup-offset-y"] = mockupOffsetY;
if (screenTop) mockupStyle["--screen-top"] = screenTop;
if (screenLeft) mockupStyle["--screen-left"] = screenLeft;
if (screenWidth) mockupStyle["--screen-width"] = screenWidth;
if (screenHeight) mockupStyle["--screen-height"] = screenHeight;

const imageStyle: Record<string, string> = {};
if (mockupOffsetY) imageStyle["--mockup-offset-y"] = mockupOffsetY;
---

<a href={withBase(href)} class="project-card">
	<div class="project-card-thumb">
		{useMockupCombo ? (
			<div class="project-card-mockup" style={mockupStyle}>
				<img
					src={withBase(thumbnail)}
					alt={thumbnailAlt}
					class="project-card-mockup-frame"
					loading="lazy"
				/>
				<video
					class="project-card-mockup-video"
					autoplay
					loop
					muted
					playsinline
					preload="metadata"
				>
					<source src={withBase(videoSrc)} type="video/mp4" />
				</video>
			</div>
		) : videoSrc ? (
			<video
				class="project-card-video"
				autoplay
				loop
				muted
				playsinline
				preload="metadata"
			>
				<source src={withBase(videoSrc)} type="video/mp4" />
			</video>
		) : thumbnail ? (
			<img
				src={withBase(thumbnail)}
				alt={thumbnailAlt}
				class="project-card-image"
				style={imageStyle}
				loading="lazy"
			/>
		) : (
			<div class="project-card-placeholder" aria-hidden="true"></div>
		)}
	</div>
	<div class="project-card-body">
		<div class="project-card-text">
			<p class="project-card-name">{name}</p>
			<p class="project-card-category">{category}</p>
		</div>
		<span class="project-card-year">{year}</span>
	</div>
</a>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--border);
		border-radius: 20px;
		/* Lightest grey by default so the card reads as clickable */
		background-color: var(--bg-secondary);
		text-decoration: none;
		overflow: hidden;
		transition: border-color var(--transition-fast),
			transform var(--transition-fast);
	}

	.project-card:hover {
		border-color: var(--text-muted);
		transform: translateY(-2px);
	}

	.project-card-thumb {
		aspect-ratio: 16 / 10;
		width: 100%;
		overflow: hidden;
		background: var(--accent-gradient, linear-gradient(to bottom, #F99E67, #FAB771));
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
	}

	.project-card-placeholder {
		width: 100%;
		height: 100%;
	}

	/* Mockup + video combo. aspectRatio is set inline per project so the
	   wrapper matches the natural mockup image ratio — video screen-coord
	   percentages then map correctly to the mockup. */
	.project-card-mockup {
		position: relative;
		max-width: var(--mockup-max, 92%);
		max-height: var(--mockup-max, 92%);
		transform: translateY(var(--mockup-offset-y, 14px));
	}

	.project-card-mockup-frame {
		position: relative;
		z-index: 1;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		pointer-events: none;
	}

	.project-card-mockup-video {
		position: absolute;
		z-index: 2;
		top: var(--screen-top, 0%);
		left: var(--screen-left, 0%);
		width: var(--screen-width, 100%);
		height: var(--screen-height, 100%);
		object-fit: cover;
		display: block;
		border-radius: 2px;
	}

	/* Static image only (no embedded video) */
	.project-card-image {
		width: 92%;
		height: 92%;
		object-fit: contain;
		display: block;
		transform: translateY(var(--mockup-offset-y, 14px));
	}

	/* Standalone video (no mockup frame) */
	.project-card-video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.project-card-body {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		padding: 16px 20px 18px;
	}

	.project-card-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.project-card-name {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-md);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.3;
	}

	.project-card-category {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: var(--text-body-sm);
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.3;
	}

	.project-card-year {
		font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 12px;
		font-weight: 500;
		color: var(--text-secondary);
		padding: 4px 10px;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-variant-numeric: tabular-nums;
		flex-shrink: 0;
		white-space: nowrap;
	}
</style>
